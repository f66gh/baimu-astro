---
import CollectionPage from '../../components/content/CollectionPage.astro';
import PageHeader from '../../components/PageHeader.astro';
import Layout from '../../layouts/Layout.astro';
import { cardPageSize, getLocalizedEntries, paginateItems } from '../../lib/content';
import { t } from '../../lib/i18n';

const lang = 'zh';
const page = paginateItems(await getLocalizedEntries('notes', lang), 1, cardPageSize);
---

<Layout title={t(lang, 'titleWithSite', { title: t(lang, 'notes'), site: t(lang, 'siteShortName') })}>
	<PageHeader eyebrow={t(lang, 'notesEyebrow')} title={t(lang, 'notes')} lede={t(lang, 'homeNotesDescription')} />
	<CollectionPage
		entries={page.items}
		collection="notes"
		lang={lang}
		view="card"
		basePath="/notes"
		currentPage={page.currentPage}
		totalPages={page.totalPages}
	/>
</Layout>
