---
import { render } from 'astro:content';
import ArticlePage from '../../components/content/ArticlePage.astro';
import Layout from '../../layouts/Layout.astro';
import { getBaseEntries } from '../../lib/content';

const lang = 'zh';

export async function getStaticPaths() {
	const entries = await getBaseEntries('notes');
	return entries.map((entry: any) => ({
		params: { slug: entry.id },
		props: {
			item: {
				entry,
				baseId: entry.id,
				isFallback: false,
			},
		},
	}));
}

const { item } = Astro.props;
const { entry } = item;
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} | 笔记`}>
	<ArticlePage
		title={entry.data.title}
		summary={entry.data.summary}
		date={entry.data.date}
		tags={entry.data.tags}
		collection="notes"
		lang={lang}
	>
		<Content />
	</ArticlePage>
</Layout>
