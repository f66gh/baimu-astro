---
import CollectionPage from '../../../../components/content/CollectionPage.astro';
import PageHeader from '../../../../components/PageHeader.astro';
import Layout from '../../../../layouts/Layout.astro';
import { getLocalizedEntries, listPageSize, numberedPagePaths, paginateItems } from '../../../../lib/content';
import { t } from '../../../../lib/i18n';

const lang = 'zh';

export async function getStaticPaths() {
	const entries = await getLocalizedEntries('notes', 'zh');
	return numberedPagePaths(entries, listPageSize);
}

const { currentPage } = Astro.props;
const page = paginateItems(await getLocalizedEntries('notes', 'zh'), currentPage, listPageSize);
---

<Layout title={t(lang, 'titleWithPageLabel', { title: `${t(lang, 'notes')}${t(lang, 'listSuffix')}`, pageLabel: t(lang, 'page', { page: currentPage }) })}>
	<PageHeader eyebrow={t(lang, 'notesEyebrow')} title={t(lang, 'notes')} lede={t(lang, 'notesListLede')} />
	<CollectionPage
		entries={page.items}
		collection="notes"
		lang={lang}
		view="list"
		basePath="/notes"
		currentPage={page.currentPage}
		totalPages={page.totalPages}
	/>
</Layout>
