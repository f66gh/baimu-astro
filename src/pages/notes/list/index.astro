---
import CollectionPage from '../../../components/content/CollectionPage.astro';
import PageHeader from '../../../components/PageHeader.astro';
import Layout from '../../../layouts/Layout.astro';
import { getLocalizedEntries, listPageSize, paginateItems } from '../../../lib/content';
import { t } from '../../../lib/i18n';

const lang = 'zh';
const page = paginateItems(await getLocalizedEntries('notes', lang), 1, listPageSize);
---

<Layout title={t(lang, 'titleWithSite', { title: `${t(lang, 'notes')}${t(lang, 'listSuffix')}`, site: t(lang, 'siteShortName') })}>
	<PageHeader eyebrow={t(lang, 'notesEyebrow')} title={t(lang, 'notes')} lede={t(lang, 'notesListLede')} />
	<CollectionPage
		entries={page.items}
		collection="notes"
		lang={lang}
		view="list"
		basePath="/notes"
		currentPage={page.currentPage}
		totalPages={page.totalPages}
	/>
</Layout>
