---
import { render } from 'astro:content';
import AnimeDetail from '../../components/anime/AnimeDetail.astro';
import Layout from '../../layouts/Layout.astro';
import { getLocalizedEntries, type LocalizedItem } from '../../lib/content';
import { t } from '../../lib/i18n';

const lang = 'zh';

export async function getStaticPaths() {
	const items = await getLocalizedEntries('anime', 'zh');
	return items.map((item) => ({
		params: { slug: item.baseId },
		props: { item },
	}));
}

const { item } = Astro.props as { item: LocalizedItem<'anime'> };
const { Content } = await render(item.entry);
---

<Layout title={t(lang, 'titleWithSection', { title: item.entry.data.title, section: t(lang, 'animeTitle') })}>
	<AnimeDetail item={item} lang={lang}>
		<Content />
	</AnimeDetail>
</Layout>
