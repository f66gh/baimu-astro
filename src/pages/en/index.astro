---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getLocalizedEntries } from '../../lib/content';
import { localizePath, t } from '../../lib/i18n';
import { getMusicTagHue } from '../../lib/music';
import { aboutParagraphs, aboutTags, mainQuestItems, siteDescriptions, siteEyebrow, siteHomeTitles, siteIdentityLines } from '../../lib/site';

const lang = 'en';
const [anime, notes, music, academic] = await Promise.all([
	getLocalizedEntries('anime', lang),
	getLocalizedEntries('notes', lang),
	getLocalizedEntries('music', lang),
	getLocalizedEntries('academic', lang),
]);

const latest = [...academic, ...notes, ...anime, ...music]
	.sort((a, b) => b.entry.data.date.valueOf() - a.entry.data.date.valueOf())
	.slice(0, 3)
	.map((item) => {
		const { entry, baseId } = item;
		const collection = entry.collection as 'academic' | 'notes' | 'anime' | 'music';
		const isExternal = collection === 'music';

		return {
			entry,
			collection,
			href: isExternal ? entry.data.url : localizePath(`/${collection}/${baseId}/`, lang),
			isExternal,
			label: t(lang, collection),
		};
	});

function getPinnedPreview(items) {
	const pinnedItem = items.find((item) => item.entry.data.pinned);
	if (!pinnedItem) return undefined;

	const { entry, baseId } = pinnedItem;
	const collection = entry.collection as 'academic' | 'notes' | 'anime' | 'music';
	const href = collection === 'music' ? entry.data.url : localizePath(`/${collection}/${baseId}/`, lang);

	return {
		title: entry.data.title,
		href,
	};
}

const stats = [
	{
		label: t(lang, 'academic'),
		value: academic.length,
		href: localizePath('/academic/', lang),
		tone: 'coral',
		description: t(lang, 'homeAcademicDescription'),
		pinned: getPinnedPreview(academic),
	},
	{
		label: t(lang, 'notes'),
		value: notes.length,
		href: localizePath('/notes/', lang),
		tone: 'teal',
		description: t(lang, 'homeNotesDescription'),
		pinned: getPinnedPreview(notes),
	},
	{
		label: t(lang, 'anime'),
		value: anime.length,
		href: localizePath('/anime/', lang),
		tone: 'violet',
		description: t(lang, 'animeLede'),
		pinned: getPinnedPreview(anime),
	},
	{
		label: t(lang, 'music'),
		value: music.length,
		href: localizePath('/music/', lang),
		tone: 'gold',
		description: t(lang, 'homeMusicDescription'),
		pinned: getPinnedPreview(music),
	},
];
---

<Layout title={siteHomeTitles[lang]} description={siteDescriptions[lang]}>
	<PageHeader eyebrow={siteEyebrow} title={siteHomeTitles[lang]} lede={siteDescriptions[lang]} />

	<section class="stat-grid" aria-label={t(lang, 'contentStats')}>
		{
			stats.map((item) => (
				<a class:list={['stat-card', `tone-${item.tone}`]} href={item.href}>
					<span>{item.label}</span>
					<strong>{item.value}</strong>
					<small>{item.description}</small>
					{
						item.pinned && (
							<em class="stat-pinned">
								{t(lang, 'currentPinned', { title: item.pinned.title })}
							</em>
						)
					}
				</a>
			))
		}
	</section>

	<section class="panel about-panel">
		<div class="about-head">
			<div>
				<h2>{t(lang, 'about')}</h2>
				<p class="identity-line">{siteIdentityLines[lang]}</p>
			</div>
			<div class="about-tags">
				{
					aboutTags.map((tag) => (
						<span style={`--tag-hue: ${getMusicTagHue(tag.zh)}`}>{tag.en}</span>
					))
				}
			</div>
		</div>
		<div class="about-copy">
			{aboutParagraphs[lang].map((paragraph, index) => <p class:list={[index === aboutParagraphs[lang].length - 1 && 'quote']}>{paragraph}</p>)}
		</div>
	</section>

	<section class="dashboard-grid">
		<article class="panel publication-panel">
			<h2>{t(lang, 'publications')}</h2>
			<p>{t(lang, 'noPublications')}</p>
		</article>

		<article class="panel quest-panel">
			<h2>{t(lang, 'mainQuest')}</h2>
			<ul>
				{
					mainQuestItems[lang].map((item) => (
						<li>
							<div class="timeline-copy">
								<strong>{item.title}</strong>
								<small>{item.description}</small>
							</div>
							<span>{item.date}</span>
						</li>
					))
				}
			</ul>
		</article>

		<article class="panel timeline-panel">
			<h2>{t(lang, 'latest')}</h2>
			<ul>
				{
					latest.map((item) => (
						<li>
							<a href={item.href} target={item.isExternal ? '_blank' : undefined} rel={item.isExternal ? 'noreferrer' : undefined}>
								<div class="timeline-copy">
									<span class:list={['timeline-badge', `tone-${item.collection === 'academic' ? 'coral' : item.collection === 'notes' ? 'teal' : item.collection === 'anime' ? 'violet' : 'gold'}`]}>
										{item.label}
									</span>
									<strong>{item.entry.data.title}</strong>
								</div>
								<span>{item.entry.data.date.toLocaleDateString('en-US')}</span>
							</a>
						</li>
					))
				}
			</ul>
		</article>
	</section>
</Layout>

<style>
	.panel,
	.stat-card {
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--panel);
		box-shadow: 0 2px 10px var(--shadow);
	}

	.stat-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 16px;
		margin: 16px 0;
	}

	.stat-card {
		position: relative;
		display: grid;
		align-content: start;
		gap: 8px;
		min-height: 168px;
		padding: 18px 18px 16px;
		overflow: hidden;
		text-decoration: none;
	}

	.stat-card::before {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 4px;
		background: var(--teal);
		content: "";
	}

	.stat-card span,
	.stat-card strong,
	.stat-card small {
		display: block;
	}

	.stat-card span {
		color: var(--muted);
		font-size: 0.94rem;
		font-weight: 750;
	}

	.stat-card strong {
		font-size: 2rem;
		line-height: 1;
	}

	.stat-card small {
		color: var(--muted);
		font-size: 0.84rem;
		line-height: 1.75;
	}

	.stat-pinned {
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
		overflow: hidden;
		color: var(--teal);
		font-size: 0.78rem;
		font-style: normal;
		font-weight: 800;
		line-height: 1.6;
	}

	.tone-coral::before {
		background: var(--coral);
	}

	.tone-violet::before {
		background: var(--violet);
	}

	.tone-gold::before {
		background: var(--gold);
	}

	.about-panel {
		padding: 20px 22px;
	}

	.about-head {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 16px;
		margin-bottom: 16px;
	}

	.about-head h2,
	.panel h2 {
		margin: 0 0 8px;
		font-size: 1rem;
	}

	.identity-line {
		margin: 0;
		color: var(--muted);
		font-size: 0.92rem;
		line-height: 1.7;
	}

	.about-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		justify-content: flex-end;
	}

	.about-tags span {
		padding: 5px 9px;
		border: 1px solid hsl(var(--tag-hue) 76% 70% / 0.6);
		border-radius: 8px;
		background: hsl(var(--tag-hue) 78% 58% / 0.14);
		color: hsl(var(--tag-hue) 56% 48%);
		font-size: 0.82rem;
		font-weight: 800;
	}

	html[data-theme='dark'] .about-tags span {
		color: hsl(var(--tag-hue) 86% 82%);
	}

	.about-copy {
		display: grid;
		gap: 12px;
	}

	.about-copy p,
	.publication-panel p {
		margin: 0;
		color: var(--muted);
		line-height: 1.82;
	}

	.about-copy .quote {
		color: var(--teal);
		font-weight: 800;
	}

	.dashboard-grid {
		display: grid;
		grid-template-columns: minmax(220px, 0.8fr) minmax(280px, 1fr) minmax(320px, 1.15fr);
		gap: 16px;
		margin-top: 16px;
	}

	.panel {
		padding: 18px;
	}

	.quest-panel ul,
	.timeline-panel ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.quest-panel li + li,
	.timeline-panel li + li {
		border-top: 1px solid var(--line);
	}

	.quest-panel li,
	.timeline-panel a {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 14px;
		padding: 12px 0;
		text-decoration: none;
	}

	.timeline-copy {
		display: grid;
		gap: 8px;
		min-width: 0;
	}

	.timeline-copy small {
		color: var(--muted);
		font-size: 0.82rem;
		line-height: 1.65;
	}

	.timeline-copy strong {
		font-size: 0.95rem;
		line-height: 1.55;
	}

	.quest-panel > ul span,
	.timeline-panel > ul span:last-child {
		flex: 0 0 auto;
		color: var(--muted);
		font-size: 0.84rem;
	}

	.timeline-badge {
		width: fit-content;
		padding: 3px 8px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--tag-bg);
		font-size: 0.74rem;
		font-weight: 800;
	}

	.timeline-badge.tone-coral {
		color: var(--coral);
	}

	.timeline-badge.tone-teal {
		color: var(--teal);
	}

	.timeline-badge.tone-violet {
		color: var(--violet);
	}

	.timeline-badge.tone-gold {
		color: var(--gold);
	}

	@media (max-width: 1120px) {
		.dashboard-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 960px) {
		.stat-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.about-head {
			flex-direction: column;
		}

		.about-tags {
			justify-content: flex-start;
		}
	}

	@media (max-width: 520px) {
		.panel,
		.about-panel {
			padding: 16px;
		}

		.stat-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 10px;
		}

		.quest-panel li,
		.timeline-panel a {
			align-items: flex-start;
			flex-direction: column;
		}
	}

	@media (max-width: 360px) {
		.stat-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
