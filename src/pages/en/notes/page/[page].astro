---
import CollectionPage from '../../../../components/content/CollectionPage.astro';
import PageHeader from '../../../../components/PageHeader.astro';
import Layout from '../../../../layouts/Layout.astro';
import { cardPageSize, getLocalizedEntries, numberedPagePaths, paginateItems } from '../../../../lib/content';
import { t } from '../../../../lib/i18n';

const lang = 'en';

export async function getStaticPaths() {
	const entries = await getLocalizedEntries('notes', 'en');
	return numberedPagePaths(entries, cardPageSize);
}

const { currentPage } = Astro.props;
const page = paginateItems(await getLocalizedEntries('notes', 'en'), currentPage, cardPageSize);
---

<Layout title={t(lang, 'titleWithPageLabel', { title: t(lang, 'notes'), pageLabel: t(lang, 'page', { page: currentPage }) })}>
	<PageHeader eyebrow={t(lang, 'notesEyebrow')} title={t(lang, 'notes')} lede={t(lang, 'homeNotesDescription')} />
	<CollectionPage
		entries={page.items}
		collection="notes"
		lang={lang}
		view="card"
		basePath="/notes"
		currentPage={page.currentPage}
		totalPages={page.totalPages}
	/>
</Layout>
