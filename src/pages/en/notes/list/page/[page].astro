---
import CollectionPage from '../../../../../components/content/CollectionPage.astro';
import PageHeader from '../../../../../components/PageHeader.astro';
import Layout from '../../../../../layouts/Layout.astro';
import { getLocalizedEntries, listPageSize, numberedPagePaths, paginateItems } from '../../../../../lib/content';

const lang = 'en';

export async function getStaticPaths() {
	const entries = await getLocalizedEntries('notes', 'en');
	return numberedPagePaths(entries, listPageSize);
}

const { currentPage } = Astro.props;
const page = paginateItems(await getLocalizedEntries('notes', 'en'), currentPage, listPageSize);
---

<Layout title={`Notes List | Page ${currentPage}`}>
	<PageHeader eyebrow="Notes" title="Notes" lede="A compact list for scanning learning notes and tool records." />
	<CollectionPage
		entries={page.items}
		collection="notes"
		lang={lang}
		view="list"
		basePath="/notes"
		currentPage={page.currentPage}
		totalPages={page.totalPages}
	/>
</Layout>
