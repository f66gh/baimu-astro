---
import { render } from 'astro:content';
import ArticlePage from '../../../components/content/ArticlePage.astro';
import Layout from '../../../layouts/Layout.astro';
import { getLocalizedEntries } from '../../../lib/content';

const lang = 'en';

export async function getStaticPaths() {
	const items = await getLocalizedEntries('notes', 'en');
	return items.map((item) => ({
		params: { slug: item.baseId },
		props: { item },
	}));
}

const { item } = Astro.props;
const { entry, isFallback } = item;
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} | Notes`}>
	<ArticlePage
		title={entry.data.title}
		summary={entry.data.summary}
		date={entry.data.date}
		tags={entry.data.tags}
		collection="notes"
		lang={lang}
		isFallback={isFallback}
	>
		<Content />
	</ArticlePage>
</Layout>
