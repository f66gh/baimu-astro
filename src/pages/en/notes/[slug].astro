---
import { render } from 'astro:content';
import ArticlePage from '../../../components/content/ArticlePage.astro';
import Layout from '../../../layouts/Layout.astro';
import { getLocalizedEntries, type LocalizedItem } from '../../../lib/content';
import { t } from '../../../lib/i18n';

const lang = 'en';

export async function getStaticPaths() {
	const items = await getLocalizedEntries('notes', 'en');
	return items.map((item) => ({
		params: { slug: item.baseId },
		props: { item },
	}));
}

const { item } = Astro.props as { item: LocalizedItem<'notes'> };
const { entry, isFallback } = item;
const { Content } = await render(entry);
---

<Layout title={t(lang, 'titleWithSection', { title: entry.data.title, section: t(lang, 'notes') })}>
	<ArticlePage
		title={entry.data.title}
		summary={entry.data.summary}
		date={entry.data.date}
		tags={entry.data.tags}
		externalUrl={entry.data.externalUrl}
		externalLabel={entry.data.externalLabel}
		collection="notes"
		lang={lang}
		isFallback={isFallback}
	>
		<Content />
	</ArticlePage>
</Layout>
