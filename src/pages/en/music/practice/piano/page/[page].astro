---
import MusicCategoryPage from '../../../../../../components/music/MusicCategoryPage.astro';
import PageHeader from '../../../../../../components/PageHeader.astro';
import { numberedPagePaths, paginateItems, getLocalizedEntries } from '../../../../../../lib/content';
import { filterMusicGroup, getMusicGroupLabel, musicPageSize } from '../../../../../../lib/music';
import { t } from '../../../../../../lib/i18n';
import Layout from '../../../../../../layouts/Layout.astro';

const lang = 'en';

export async function getStaticPaths() {
	const entries = filterMusicGroup(await getLocalizedEntries('music', 'en'), 'piano');
	return numberedPagePaths(entries, musicPageSize);
}

const { currentPage } = Astro.props;
const entries = filterMusicGroup(await getLocalizedEntries('music', lang), 'piano');
const page = paginateItems(entries, currentPage, musicPageSize);
---

<Layout title={`Piano Practice Page ${page.currentPage} | Music`}>
	<PageHeader eyebrow={t(lang, 'musicEyebrow')} title={getMusicGroupLabel('piano', lang)} lede="The full piano practice wall, sorted by date in descending order, 16 cards per page." />
	<MusicCategoryPage group="piano" entries={page.items} basePath="/music/practice/piano" currentPage={page.currentPage} totalPages={page.totalPages} lang={lang} />
</Layout>
