---
import MusicCategoryPage from '../../../../../components/music/MusicCategoryPage.astro';
import PageHeader from '../../../../../components/PageHeader.astro';
import { paginateItems, getLocalizedEntries } from '../../../../../lib/content';
import { filterMusicGroup, getMusicGroupLabel, musicPageSize } from '../../../../../lib/music';
import { t } from '../../../../../lib/i18n';
import Layout from '../../../../../layouts/Layout.astro';

const lang = 'en';
const entries = filterMusicGroup(await getLocalizedEntries('music', lang), 'violin');
const page = paginateItems(entries, 1, musicPageSize);
---

<Layout title="Violin Practice | Music">
	<PageHeader eyebrow={t(lang, 'musicEyebrow')} title={getMusicGroupLabel('violin', lang)} lede="The full violin practice wall, sorted by date in descending order, 16 cards per page." />
	<MusicCategoryPage group="violin" entries={page.items} basePath="/music/practice/violin" currentPage={page.currentPage} totalPages={page.totalPages} lang={lang} />
</Layout>
