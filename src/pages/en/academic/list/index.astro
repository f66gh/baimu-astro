---
import CollectionPage from '../../../../components/content/CollectionPage.astro';
import PageHeader from '../../../../components/PageHeader.astro';
import Layout from '../../../../layouts/Layout.astro';
import { getLocalizedEntries, listPageSize, paginateItems } from '../../../../lib/content';

const lang = 'en';
const page = paginateItems(await getLocalizedEntries('academic', lang), 1, listPageSize);
---

<Layout title="Academic List | Aiu Web">
	<PageHeader eyebrow="Academic" title="Academic" lede="A compact list for quickly scanning research notes and tasks." />
	<CollectionPage
		entries={page.items}
		collection="academic"
		lang={lang}
		view="list"
		basePath="/academic"
		currentPage={page.currentPage}
		totalPages={page.totalPages}
	/>
</Layout>
