---
import { getCollection } from 'astro:content';
import ContentCard from '../components/ContentCard.astro';
import Layout from '../layouts/Layout.astro';

const [anime, notes, videos, academic] = await Promise.all([
	getCollection('anime'),
	getCollection('notes'),
	getCollection('videos'),
	getCollection('academic'),
]);

const latest = [...notes, ...academic]
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);
---

<Layout title="Aiu 的个人内容中心">
	<section class="home-hero">
		<div>
			<p class="eyebrow">Personal Lab</p>
			<h1 class="page-title">把学术、追番、笔记和灵感放在同一个星图里。</h1>
			<p class="lede">
				这里先长出一个能用的骨架：内容可以按集合管理，页面可以继续扩展，之后再接 GitHub Actions 和 Decap CMS。
			</p>
		</div>
		<img
			src="https://images.unsplash.com/photo-1518005020951-eccb494ad742?auto=format&fit=crop&w=1000&q=80"
			alt=""
		/>
	</section>

	<section class="quick-grid" aria-label="内容入口">
		<a href="/academic/"><strong>学术进展</strong><span>{academic.length} 条记录</span></a>
		<a href="/anime/"><strong>追番列表</strong><span>{anime.length} 部作品</span></a>
		<a href="/notes/"><strong>个人笔记</strong><span>{notes.length} 篇笔记</span></a>
		<a href="/videos/"><strong>B 站视频</strong><span>{videos.length} 个链接</span></a>
	</section>

	<div class="section-head">
		<h2>最近更新</h2>
		<a href="/notes/">看全部</a>
	</div>
	<section class="grid">
		{
			latest.map((entry) => (
				<ContentCard
					href={`/${entry.collection}/${entry.id}/`}
					title={entry.data.title}
					summary={entry.data.summary}
					date={entry.data.date}
					cover={entry.data.cover}
					tags={entry.data.tags}
					accent={entry.collection === 'academic' ? 'coral' : 'teal'}
				/>
			))
		}
	</section>
</Layout>

<style>
	.home-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(280px, 0.72fr);
		align-items: center;
		gap: 34px;
		min-height: 60vh;
		padding: 28px 0;
	}

	.home-hero img {
		width: 100%;
		aspect-ratio: 4 / 5;
		border: 1px solid var(--line);
		border-radius: 8px;
		object-fit: cover;
		box-shadow: 0 22px 60px rgba(60, 64, 67, 0.14);
	}

	.quick-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 12px;
		margin-top: 18px;
	}

	.quick-grid a {
		min-height: 110px;
		padding: 18px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #ffffff;
		text-decoration: none;
	}

	.quick-grid strong,
	.quick-grid span {
		display: block;
	}

	.quick-grid strong {
		margin-bottom: 22px;
		font-size: 1.1rem;
	}

	.quick-grid span {
		color: var(--muted);
	}

	@media (max-width: 820px) {
		.home-hero {
			grid-template-columns: 1fr;
			min-height: auto;
		}

		.home-hero img {
			aspect-ratio: 16 / 10;
		}

		.quick-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 520px) {
		.quick-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
