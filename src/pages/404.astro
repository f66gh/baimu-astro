---
import Layout from '../layouts/Layout.astro';
import { getLangFromPath, localizePath, t } from '../lib/i18n';

const lang = getLangFromPath(Astro.url.pathname);
---

<Layout title="404 | 白木的个人主页">
	<section class="not-found">
		<p class="eyebrow">404</p>
		<h1 class="page-title">{t(lang, 'notFoundTitle')}</h1>
		<p class="lede">{t(lang, 'notFoundLede')}</p>
		<div class="not-found-actions">
			<a href={localizePath('/', lang)}>{t(lang, 'backToHome')}</a>
			<a href={localizePath('/academic/', lang)}>{t(lang, 'backToAcademic')}</a>
			<a href={localizePath('/notes/', lang)}>{t(lang, 'backToNotes')}</a>
		</div>
	</section>
</Layout>

<style>
	.not-found {
		display: grid;
		gap: 14px;
		align-content: center;
		min-height: calc(100dvh - 120px);
		padding: 24px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--panel);
		box-shadow: 0 2px 10px var(--shadow);
	}

	.not-found-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 4px;
	}

	.not-found-actions a {
		display: inline-flex;
		align-items: center;
		padding: 10px 14px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--button-bg);
		color: var(--teal);
		font-weight: 800;
		text-decoration: none;
	}
</style>
