---
import CollectionPage from '../../../components/content/CollectionPage.astro';
import PageHeader from '../../../components/PageHeader.astro';
import Layout from '../../../layouts/Layout.astro';
import { getLocalizedEntries, listPageSize, paginateItems } from '../../../lib/content';

const lang = 'zh';
const page = paginateItems(await getLocalizedEntries('academic', lang), 1, listPageSize);
---

<Layout title="学术进展列表 | Aiu Web">
	<PageHeader eyebrow="Academic" title="学术进展" lede="用更紧凑的列表快速回看论文阅读、组内任务和想法总结。" />
	<CollectionPage
		entries={page.items}
		collection="academic"
		lang={lang}
		view="list"
		basePath="/academic"
		currentPage={page.currentPage}
		totalPages={page.totalPages}
	/>
</Layout>
