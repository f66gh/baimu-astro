---
import CollectionPage from '../../../../components/content/CollectionPage.astro';
import PageHeader from '../../../../components/PageHeader.astro';
import Layout from '../../../../layouts/Layout.astro';
import { getLocalizedEntries, listPageSize, numberedPagePaths, paginateItems } from '../../../../lib/content';
import { t } from '../../../../lib/i18n';

const lang = 'zh';

export async function getStaticPaths() {
	const entries = await getLocalizedEntries('academic', 'zh');
	return numberedPagePaths(entries, listPageSize);
}

const { currentPage } = Astro.props;
const page = paginateItems(await getLocalizedEntries('academic', 'zh'), currentPage, listPageSize);
---

<Layout title={t(lang, 'titleWithPageLabel', { title: `${t(lang, 'academic')}${t(lang, 'listSuffix')}`, pageLabel: t(lang, 'page', { page: currentPage }) })}>
	<PageHeader eyebrow={t(lang, 'academicEyebrow')} title={t(lang, 'academic')} lede={t(lang, 'academicListLede')} />
	<CollectionPage
		entries={page.items}
		collection="academic"
		lang={lang}
		view="list"
		basePath="/academic"
		currentPage={page.currentPage}
		totalPages={page.totalPages}
	/>
</Layout>
