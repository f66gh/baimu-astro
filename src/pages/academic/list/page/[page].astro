---
import CollectionPage from '../../../../components/content/CollectionPage.astro';
import PageHeader from '../../../../components/PageHeader.astro';
import Layout from '../../../../layouts/Layout.astro';
import { getLocalizedEntries, listPageSize, numberedPagePaths, paginateItems } from '../../../../lib/content';

const lang = 'zh';

export async function getStaticPaths() {
	const entries = await getLocalizedEntries('academic', 'zh');
	return numberedPagePaths(entries, listPageSize);
}

const { currentPage } = Astro.props;
const page = paginateItems(await getLocalizedEntries('academic', 'zh'), currentPage, listPageSize);
---

<Layout title={`学术进展列表 | 第 ${currentPage} 页`}>
	<PageHeader eyebrow="Academic" title="学术进展" lede="用更紧凑的列表快速回看论文阅读、组内任务和想法总结。" />
	<CollectionPage
		entries={page.items}
		collection="academic"
		lang={lang}
		view="list"
		basePath="/academic"
		currentPage={page.currentPage}
		totalPages={page.totalPages}
	/>
</Layout>
