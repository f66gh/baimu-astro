---
import CollectionPage from '../../../components/content/CollectionPage.astro';
import PageHeader from '../../../components/PageHeader.astro';
import Layout from '../../../layouts/Layout.astro';
import { cardPageSize, getLocalizedEntries, numberedPagePaths, paginateItems } from '../../../lib/content';
import { t } from '../../../lib/i18n';

const lang = 'zh';

export async function getStaticPaths() {
	const entries = await getLocalizedEntries('academic', 'zh');
	return numberedPagePaths(entries, cardPageSize);
}

const { currentPage } = Astro.props;
const page = paginateItems(await getLocalizedEntries('academic', 'zh'), currentPage, cardPageSize);
---

<Layout title={t(lang, 'titleWithPageLabel', { title: t(lang, 'academic'), pageLabel: t(lang, 'page', { page: currentPage }) })}>
	<PageHeader eyebrow={t(lang, 'academicEyebrow')} title={t(lang, 'academic')} lede={t(lang, 'homeAcademicDescription')} />
	<CollectionPage
		entries={page.items}
		collection="academic"
		lang={lang}
		view="card"
		basePath="/academic"
		currentPage={page.currentPage}
		totalPages={page.totalPages}
	/>
</Layout>
