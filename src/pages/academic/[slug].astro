---
import { render } from 'astro:content';
import ArticlePage from '../../components/content/ArticlePage.astro';
import Layout from '../../layouts/Layout.astro';
import { getLocalizedEntries, type LocalizedItem } from '../../lib/content';

const lang = 'zh';

export async function getStaticPaths() {
	const items = await getLocalizedEntries('academic', 'zh');
	return items.map((item) => ({
		params: { slug: item.baseId },
		props: { item },
	}));
}

const { item } = Astro.props as { item: LocalizedItem<'academic'> };
const { entry } = item;
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} | 学术`}>
	<ArticlePage
		title={entry.data.title}
		summary={entry.data.summary}
		date={entry.data.date}
		tags={entry.data.tags}
		collection="academic"
		lang={lang}
	>
		<Content />
	</ArticlePage>
</Layout>
