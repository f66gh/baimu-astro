---
import CollectionPage from '../../components/content/CollectionPage.astro';
import PageHeader from '../../components/PageHeader.astro';
import Layout from '../../layouts/Layout.astro';
import { cardPageSize, getLocalizedEntries, paginateItems } from '../../lib/content';

const lang = 'zh';
const page = paginateItems(await getLocalizedEntries('academic', lang), 1, cardPageSize);
---

<Layout title="学术进展 | Aiu Web">
	<PageHeader eyebrow="Academic" title="学术进展" lede="记录论文阅读、组内任务，以及想法与阶段性总结。" />
	<CollectionPage
		entries={page.items}
		collection="academic"
		lang={lang}
		view="card"
		basePath="/academic"
		currentPage={page.currentPage}
		totalPages={page.totalPages}
	/>
</Layout>
