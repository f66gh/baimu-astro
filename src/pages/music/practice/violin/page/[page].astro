---
import MusicCategoryPage from '../../../../../components/music/MusicCategoryPage.astro';
import PageHeader from '../../../../../components/PageHeader.astro';
import { numberedPagePaths, paginateItems, getLocalizedEntries } from '../../../../../lib/content';
import { filterMusicGroup, getMusicGroupLabel, musicPageSize } from '../../../../../lib/music';
import { t } from '../../../../../lib/i18n';
import Layout from '../../../../../layouts/Layout.astro';

const lang = 'zh';

export async function getStaticPaths() {
	const entries = filterMusicGroup(await getLocalizedEntries('music', 'zh'), 'violin');
	return numberedPagePaths(entries, musicPageSize);
}

const { currentPage } = Astro.props;
const entries = filterMusicGroup(await getLocalizedEntries('music', lang), 'violin');
const page = paginateItems(entries, currentPage, musicPageSize);
---

<Layout title={t(lang, 'titleWithPageLabel', { title: getMusicGroupLabel('violin', lang), pageLabel: t(lang, 'page', { page: page.currentPage }) })}>
	<PageHeader eyebrow={t(lang, 'musicEyebrow')} title={getMusicGroupLabel('violin', lang)} lede={t(lang, 'violinLede')} />
	<MusicCategoryPage
		group="violin"
		entries={page.items}
		basePath="/music/practice/violin"
		currentPage={page.currentPage}
		totalPages={page.totalPages}
		lang={lang}
	/>
</Layout>
