---
import MusicCategoryPage from '../../../../../components/music/MusicCategoryPage.astro';
import PageHeader from '../../../../../components/PageHeader.astro';
import { numberedPagePaths, paginateItems, getLocalizedEntries } from '../../../../../lib/content';
import { filterMusicGroup, getMusicGroupLabel, musicPageSize } from '../../../../../lib/music';
import { t } from '../../../../../lib/i18n';
import Layout from '../../../../../layouts/Layout.astro';

const lang = 'zh';

export async function getStaticPaths() {
	const entries = filterMusicGroup(await getLocalizedEntries('music', 'zh'), 'piano');
	return numberedPagePaths(entries, musicPageSize);
}

const { currentPage } = Astro.props;
const entries = filterMusicGroup(await getLocalizedEntries('music', lang), 'piano');
const page = paginateItems(entries, currentPage, musicPageSize);
---

<Layout title={`钢琴练习第 ${page.currentPage} 页 | 白木的个人主页`}>
	<PageHeader eyebrow={t(lang, 'musicEyebrow')} title={getMusicGroupLabel('piano', lang)} lede="这里放完整的钢琴练习视频卡片墙。按时间降序排列，每页 16 张。" />
	<MusicCategoryPage
		group="piano"
		entries={page.items}
		basePath="/music/practice/piano"
		currentPage={page.currentPage}
		totalPages={page.totalPages}
		lang={lang}
	/>
</Layout>
