---
import MusicCategoryPage from '../../../../components/music/MusicCategoryPage.astro';
import PageHeader from '../../../../components/PageHeader.astro';
import { paginateItems, getLocalizedEntries } from '../../../../lib/content';
import { filterMusicGroup, getMusicGroupLabel, musicPageSize } from '../../../../lib/music';
import { t } from '../../../../lib/i18n';
import Layout from '../../../../layouts/Layout.astro';

const lang = 'zh';
const entries = filterMusicGroup(await getLocalizedEntries('music', lang), 'pop');
const page = paginateItems(entries, 1, musicPageSize);
---

<Layout title="流行鉴赏 | 白木的个人主页">
	<PageHeader eyebrow={t(lang, 'musicEyebrow')} title={getMusicGroupLabel('pop', lang)} lede="这里放完整的流行鉴赏卡片墙。按时间降序排列，每页 16 张。" />
	<MusicCategoryPage
		group="pop"
		entries={page.items}
		basePath="/music/library/pop"
		currentPage={page.currentPage}
		totalPages={page.totalPages}
		lang={lang}
	/>
</Layout>
