---
import MusicCategoryPage from '../../../../components/music/MusicCategoryPage.astro';
import PageHeader from '../../../../components/PageHeader.astro';
import { paginateItems, getLocalizedEntries } from '../../../../lib/content';
import { filterMusicGroup, getMusicGroupLabel, musicPageSize } from '../../../../lib/music';
import { t } from '../../../../lib/i18n';
import Layout from '../../../../layouts/Layout.astro';

const lang = 'zh';
const entries = filterMusicGroup(await getLocalizedEntries('music', lang), 'classical');
const page = paginateItems(entries, 1, musicPageSize);
---

<Layout title={t(lang, 'titleWithSite', { title: getMusicGroupLabel('classical', lang), site: t(lang, 'siteShortName') })}>
	<PageHeader eyebrow={t(lang, 'musicEyebrow')} title={getMusicGroupLabel('classical', lang)} lede={t(lang, 'classicalLede')} />
	<MusicCategoryPage
		group="classical"
		entries={page.items}
		basePath="/music/library/classical"
		currentPage={page.currentPage}
		totalPages={page.totalPages}
		lang={lang}
	/>
</Layout>
