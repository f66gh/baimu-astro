---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Aiu 的个人站',
	description = '学术进展、追番记录、个人笔记和视频收藏。',
} = Astro.props;

const navItems = [
	{ href: '/', label: '首页', icon: '⌂' },
	{ href: '/academic/', label: '学术进展', icon: '◆' },
	{ href: '/anime/', label: '追番列表', icon: '◉' },
	{ href: '/notes/', label: '个人笔记', icon: '✎' },
	{ href: '/videos/', label: '视频收藏', icon: '▶' },
];

const socialItems = [
	{ href: 'https://github.com/', label: 'GitHub' },
	{ href: 'https://space.bilibili.com/', label: 'Bilibili' },
	{ href: 'https://tieba.baidu.com/', label: '贴吧' },
	{ href: 'mailto:yourname@gmail.com', label: 'Gmail' },
];

const currentPath = Astro.url.pathname;
const activeItem =
	navItems
		.filter((item) => item.href !== '/')
		.find((item) => currentPath.startsWith(item.href)) ?? navItems[0];
const pageName = title.split('|')[0].trim();
const breadcrumb = currentPath === '/'
	? ['首页']
	: ['首页', activeItem.label, ...(pageName && pageName !== activeItem.label ? [pageName] : [])];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<div class="admin-shell">
			<aside class="sidebar" aria-label="站点导航">
				<a class="brand" href="/">
					<span class="brand-mark">A</span>
					<span>Aiu 控制台</span>
				</a>
				<nav>
					{
						navItems.map((item) => {
							const isActive = item.href === '/'
								? currentPath === '/'
								: currentPath.startsWith(item.href);

							return (
								<a href={item.href} aria-current={isActive ? 'page' : undefined}>
									<span>{item.icon}</span>
									{item.label}
								</a>
							);
						})
					}
				</nav>
			</aside>
			<section class="workbench">
				<header class="topbar">
					<div class="breadcrumb" aria-label="页面层级">
						{
							breadcrumb.map((item, index) => (
								<>
									<span>{item}</span>
									{index < breadcrumb.length - 1 && <b>/</b>}
								</>
							))
						}
					</div>
					<nav class="social-nav" aria-label="社交平台">
						{
							socialItems.map((item) => (
								<a href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
							))
						}
					</nav>
				</header>
				<main>
					<slot />
				</main>
			</section>
		</div>
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		--ink: #202327;
		--muted: #6b7280;
		--line: #e5e7eb;
		--paper: #f3f5f8;
		--panel: #ffffff;
		--sidebar: #14181f;
		--sidebar-soft: #1d232d;
		--sidebar-text: #c8d0dc;
		--sidebar-strong: #ffffff;
		--wash: #f8fafc;
		--coral: #e65f4c;
		--teal: #009688;
		--leaf: #4d7c0f;
		--violet: #6d5bd0;
		--gold: #b7791f;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	html {
		background: var(--paper);
		color: var(--ink);
	}

	body {
		margin: 0;
		min-width: 320px;
	}

	a {
		color: inherit;
		text-decoration-color: rgba(0, 121, 107, 0.38);
		text-underline-offset: 0.18em;
	}

	img {
		display: block;
		max-width: 100%;
	}

	.admin-shell {
		display: grid;
		grid-template-columns: 232px minmax(0, 1fr);
		min-height: 100vh;
		background: var(--paper);
	}

	.sidebar {
		position: sticky;
		top: 0;
		height: 100vh;
		overflow-y: auto;
		background: var(--sidebar);
		box-shadow: 2px 0 10px rgba(17, 19, 22, 0.18);
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 10px;
		height: 56px;
		padding: 0 18px;
		color: var(--sidebar-strong);
		font-weight: 800;
		text-decoration: none;
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}

	.brand-mark {
		display: inline-grid;
		place-items: center;
		width: 28px;
		height: 28px;
		border: 1px solid rgba(0, 150, 136, 0.7);
		border-radius: 8px;
		background: rgba(0, 150, 136, 0.16);
		color: #5eead4;
	}

	nav {
		padding: 12px 0;
	}

	nav a {
		display: flex;
		align-items: center;
		gap: 11px;
		min-height: 44px;
		padding: 0 18px;
		color: var(--sidebar-text);
		font-size: 0.94rem;
		font-weight: 650;
		text-decoration: none;
		border-left: 3px solid transparent;
	}

	nav a span {
		width: 20px;
		color: #95a3b8;
		text-align: center;
	}

	nav a[aria-current="page"],
	nav a:hover {
		background: var(--sidebar-soft);
		color: var(--sidebar-strong);
		border-left-color: var(--teal);
	}

	.workbench {
		min-width: 0;
	}

	.topbar {
		position: sticky;
		top: 0;
		z-index: 4;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 18px;
		min-height: 56px;
		padding: 0 22px;
		background: var(--panel);
		border-bottom: 1px solid var(--line);
		box-shadow: 0 1px 4px rgba(32, 35, 39, 0.06);
	}

	.breadcrumb {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 9px;
		color: #4b5563;
		font-size: 0.94rem;
	}

	.breadcrumb span:last-of-type {
		color: var(--ink);
		font-weight: 700;
	}

	.breadcrumb b {
		color: #b5bdc9;
		font-weight: 500;
	}

	.social-nav {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		flex-wrap: wrap;
		gap: 8px;
		padding: 0;
	}

	.social-nav a {
		min-height: 32px;
		padding: 0 10px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #ffffff;
		color: #4b5563;
		font-size: 0.87rem;
	}

	.social-nav a:hover {
		background: #f8fafc;
		color: var(--teal);
		border-left-color: var(--line);
	}

	main {
		padding: 18px;
	}

	:global(.eyebrow) {
		margin: 0 0 8px;
		color: var(--teal);
		font-size: 0.86rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	:global(.page-title) {
		max-width: 820px;
		margin: 0;
		font-size: 1.55rem;
		line-height: 1.25;
		letter-spacing: 0;
	}

	:global(.lede) {
		max-width: 720px;
		margin: 10px 0 0;
		color: var(--muted);
		font-size: 0.98rem;
		line-height: 1.75;
	}

	:global(.section-head) {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 20px;
		margin: 20px 0 12px;
	}

	:global(.section-head h2) {
		margin: 0;
		font-size: 1.55rem;
	}

	:global(.section-head a) {
		color: var(--teal);
		font-weight: 750;
	}

	:global(.grid) {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 16px;
	}

	:global(.tag-list) {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin: 14px 0 0;
		padding: 0;
		list-style: none;
	}

	:global(.tag-list li) {
		padding: 5px 8px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.7);
		color: var(--muted);
		font-size: 0.82rem;
	}

	:global(.prose) {
		max-width: 760px;
		padding: 20px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--panel);
	}

	:global(.prose p),
	:global(.prose li) {
		color: #303134;
		font-size: 1.02rem;
		line-height: 1.9;
	}

	:global(.prose h2) {
		margin-top: 34px;
	}

	@media (max-width: 820px) {
		.admin-shell {
			grid-template-columns: 1fr;
		}

		.sidebar {
			position: static;
			height: auto;
		}

		.brand {
			height: 52px;
		}

		.sidebar nav {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			padding: 8px;
		}

		.sidebar nav a {
			border-left: 0;
			border-radius: 8px;
		}

		.topbar {
			position: static;
			align-items: flex-start;
			flex-direction: column;
			padding: 12px 16px;
		}

		:global(.page-title) {
			font-size: 1.35rem;
		}

		main {
			padding: 14px;
		}
	}

	@media (max-width: 520px) {
		.sidebar nav {
			grid-template-columns: 1fr;
		}

		.social-nav {
			justify-content: flex-start;
		}
	}
</style>
