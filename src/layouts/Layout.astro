---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Aiu 的个人站',
	description = '学术进展、追番记录、个人笔记和视频收藏。',
} = Astro.props;

const navItems = [
	{ href: '/', label: '首页' },
	{ href: '/academic/', label: '学术' },
	{ href: '/anime/', label: '追番' },
	{ href: '/notes/', label: '笔记' },
	{ href: '/videos/', label: '视频' },
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href="/">Aiu Web</a>
			<nav aria-label="主导航">
				{
					navItems.map((item) => (
						<a href={item.href} aria-current={Astro.url.pathname === item.href ? 'page' : undefined}>
							{item.label}
						</a>
					))
				}
			</nav>
		</header>
		<main>
			<slot />
		</main>
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		--ink: #202124;
		--muted: #5f6368;
		--line: #dadce0;
		--paper: #fffdf9;
		--wash: #f6f8f1;
		--coral: #e65f4c;
		--teal: #00796b;
		--leaf: #4d7c0f;
		--violet: #6d5bd0;
		--gold: #b7791f;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	html {
		background: var(--paper);
		color: var(--ink);
	}

	body {
		margin: 0;
		min-width: 320px;
	}

	body::before {
		position: fixed;
		inset: 0;
		z-index: -1;
		background:
			linear-gradient(90deg, rgba(230, 95, 76, 0.08), transparent 35%),
			linear-gradient(180deg, rgba(0, 121, 107, 0.1), transparent 42%),
			var(--paper);
		content: "";
	}

	a {
		color: inherit;
		text-decoration-color: rgba(0, 121, 107, 0.38);
		text-underline-offset: 0.18em;
	}

	img {
		display: block;
		max-width: 100%;
	}

	main {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 40px 0 72px;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 5;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 20px;
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 18px 0;
		background: rgba(255, 253, 249, 0.86);
		backdrop-filter: blur(14px);
		border-bottom: 1px solid rgba(218, 220, 224, 0.72);
	}

	.brand {
		font-weight: 800;
		text-decoration: none;
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 8px;
	}

	nav a {
		padding: 8px 10px;
		border-radius: 8px;
		color: var(--muted);
		font-size: 0.95rem;
		font-weight: 650;
		text-decoration: none;
	}

	nav a[aria-current="page"],
	nav a:hover {
		background: #ffffff;
		color: var(--teal);
		box-shadow: inset 0 0 0 1px var(--line);
	}

	:global(.eyebrow) {
		margin: 0 0 10px;
		color: var(--coral);
		font-size: 0.86rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	:global(.page-title) {
		max-width: 820px;
		margin: 0;
		font-size: 4.6rem;
		line-height: 0.96;
		letter-spacing: 0;
	}

	:global(.lede) {
		max-width: 720px;
		margin: 18px 0 0;
		color: var(--muted);
		font-size: 1.1rem;
		line-height: 1.8;
	}

	:global(.section-head) {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 20px;
		margin: 56px 0 18px;
	}

	:global(.section-head h2) {
		margin: 0;
		font-size: 1.55rem;
	}

	:global(.section-head a) {
		color: var(--teal);
		font-weight: 750;
	}

	:global(.grid) {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 18px;
	}

	:global(.tag-list) {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin: 14px 0 0;
		padding: 0;
		list-style: none;
	}

	:global(.tag-list li) {
		padding: 5px 8px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.7);
		color: var(--muted);
		font-size: 0.82rem;
	}

	:global(.prose) {
		max-width: 760px;
	}

	:global(.prose p),
	:global(.prose li) {
		color: #303134;
		font-size: 1.02rem;
		line-height: 1.9;
	}

	:global(.prose h2) {
		margin-top: 34px;
	}

	@media (max-width: 680px) {
		:global(.page-title) {
			font-size: 2.55rem;
		}

		.site-header {
			position: static;
			align-items: flex-start;
			flex-direction: column;
		}

		nav {
			justify-content: flex-start;
		}

		main {
			padding-top: 26px;
		}
	}
</style>
