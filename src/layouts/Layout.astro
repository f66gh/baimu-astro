---
import { Icon } from 'astro-icon/components';
import { getLangFromPath, localizePath, stripLangPrefix, t, toggleLangPath } from '../lib/i18n';
import { gmailAddress, siteAvatar, siteDescriptions, siteName, socialLinks } from '../lib/site';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = siteName,
	description,
} = Astro.props;

const currentPath = Astro.url.pathname;
const cleanPath = stripLangPrefix(currentPath);
const lang = getLangFromPath(currentPath);
const pageDescription = description ?? siteDescriptions[lang];

const navItems = [
	{ href: '/', labelKey: 'home', icon: 'mdi:view-dashboard-outline', localized: true },
	{ href: '/academic/', labelKey: 'academic', icon: 'mdi:school-outline', localized: true },
	{ href: '/notes/', labelKey: 'notes', icon: 'mdi:notebook-edit-outline', localized: true },
	{ href: '/anime/', labelKey: 'anime', icon: 'mdi:television-classic', localized: true },
	{ href: '/music/', labelKey: 'music', icon: 'mdi:music', localized: true },
];

const socialItems = [
	{ href: socialLinks.github, label: 'GitHub', icon: 'mdi:github', kind: 'link' },
	{ href: socialLinks.bilibili, label: 'Bilibili', icon: 'simple-icons:bilibili', kind: 'link' },
	{ href: socialLinks.tieba, label: '贴吧', icon: 'simple-icons:baidu', kind: 'link' },
	{ label: t(lang, 'copyMail'), icon: 'mdi:gmail', kind: 'copy' },
];
const activeItem =
	navItems
		.filter((item) => item.href !== '/')
		.find((item) => cleanPath.startsWith(item.href)) ?? navItems[0];
const pageName = title.split('|')[0].trim();
const activeLabel = t(lang, activeItem.labelKey);
const breadcrumb = cleanPath === '/'
	? [t(lang, 'home')]
	: [t(lang, 'home'), activeLabel, ...(pageName && pageName !== activeLabel ? [pageName] : [])];
const nextLangPath = toggleLangPath(currentPath);
const langLabel = lang === 'en' ? '中文' : 'EN';
const themeLightLabel = t(lang, 'themeLight');
const themeDarkLabel = t(lang, 'themeDark');
const openNavLabel = t(lang, 'openNav');
const closeNavLabel = t(lang, 'closeNav');
const siteNavLabel = t(lang, 'siteNav');
const breadcrumbNavLabel = t(lang, 'breadcrumbNav');
const socialNavLabel = t(lang, 'socialNav');
const toggleLanguageLabel = t(lang, 'toggleLanguage');
const toggleThemeLabel = t(lang, 'toggleTheme');
---

<!doctype html>
<html lang={lang === 'en' ? 'en' : 'zh-CN'}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/jpeg" href={siteAvatar} />
		<link rel="shortcut icon" type="image/jpeg" href={siteAvatar} />
		<link rel="apple-touch-icon" href={siteAvatar} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={pageDescription} />
		<title>{title}</title>
		<script is:inline>
			(() => {
				const storageKey = 'aiu-theme';
				const stored = localStorage.getItem(storageKey);
				const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				const theme = stored === 'light' || stored === 'dark'
					? stored
					: systemDark
						? 'dark'
						: 'light';

				document.documentElement.dataset.theme = theme;
				document.documentElement.style.colorScheme = theme;
			})();
		</script>
		<style is:inline></style>
	</head>
	<body>
		<div class="admin-shell">
			<button class="drawer-backdrop" type="button" data-drawer-close aria-label={closeNavLabel}></button>
				<aside class="sidebar" id="site-sidebar" aria-label={siteNavLabel}>
					<a class="brand" href={localizePath('/', lang)}>
						<img class="brand-avatar" src={siteAvatar} alt="" />
						<span>{siteName}</span>
					</a>
				<nav>
						{
							navItems.map((item) => {
								const isActive = item.href === '/'
									? cleanPath === '/'
									: cleanPath.startsWith(item.href);

								return (
									<a
										href={item.localized ? localizePath(item.href, lang) : item.href}
										aria-current={isActive ? 'page' : undefined}
									>
										<Icon class="nav-icon" name={item.icon} size="19" aria-hidden="true" />
										{t(lang, item.labelKey)}
									</a>
								);
							})
					}
				</nav>
			</aside>
			<section class="workbench">
				<header class="topbar">
					<div class="topbar-primary">
						<button
							class="menu-toggle"
							type="button"
							data-drawer-toggle
							aria-controls="site-sidebar"
							aria-expanded="false"
							aria-label={openNavLabel}
						>
							<Icon name="mdi:menu" size="22" aria-hidden="true" />
						</button>
						<div class="breadcrumb" aria-label={breadcrumbNavLabel}>
							{
								breadcrumb.map((item, index) => (
									<>
										<span>{item}</span>
										{index < breadcrumb.length - 1 && <b>/</b>}
									</>
								))
							}
						</div>
					</div>
					<div class="top-actions">
						<nav class="social-nav" aria-label={socialNavLabel}>
							{
								socialItems.map((item) =>
									item.kind === 'link' ? (
										<a href={item.href} target="_blank" rel="noreferrer" aria-label={item.label}>
											<Icon name={item.icon} size="18" aria-hidden="true" />
											<span>{item.label}</span>
										</a>
									) : (
										<button
											type="button"
											class="social-button"
											data-copy-email={gmailAddress}
											data-copy-label={t(lang, 'copyMail')}
											data-copy-done={t(lang, 'copyMailDone')}
											aria-label={item.label}
										>
											<Icon name={item.icon} size="18" aria-hidden="true" />
											<span data-copy-text>{item.label}</span>
										</button>
									),
								)
							}
						</nav>
						<a class="lang-toggle" href={nextLangPath} aria-label={toggleLanguageLabel} title={toggleLanguageLabel}>
							<Icon name="mdi:translate" size="18" aria-hidden="true" />
							<span>{langLabel}</span>
						</a>
						<button
							class="theme-toggle"
							type="button"
							data-theme-toggle
							data-theme-light={themeLightLabel}
							data-theme-dark={themeDarkLabel}
							aria-label={toggleThemeLabel}
							aria-pressed="false"
						>
							<Icon class="theme-icon theme-icon-light" name="mdi:weather-sunny" size="18" aria-hidden="true" />
							<Icon class="theme-icon theme-icon-dark" name="mdi:weather-night" size="18" aria-hidden="true" />
							<span data-theme-label>{themeLightLabel}</span>
						</button>
					</div>
				</header>
				<main>
					<slot />
				</main>
			</section>
		</div>
		<script is:inline>
			(() => {
				const storageKey = 'aiu-theme';
				const root = document.documentElement;
				const button = document.querySelector('[data-theme-toggle]');
				const label = document.querySelector('[data-theme-label]');
				const lightLabel = button?.dataset.themeLight ?? 'Light';
				const darkLabel = button?.dataset.themeDark ?? 'Dark';

				const setTheme = (theme) => {
					root.dataset.theme = theme;
					root.style.colorScheme = theme;
					localStorage.setItem(storageKey, theme);

					if (button) {
						button.setAttribute('aria-pressed', String(theme === 'dark'));
					}

					if (label) {
						label.textContent = theme === 'dark' ? darkLabel : lightLabel;
					}
				};

				setTheme(root.dataset.theme === 'dark' ? 'dark' : 'light');
				button?.addEventListener('click', () => {
					setTheme(root.dataset.theme === 'dark' ? 'light' : 'dark');
				});
			})();
		</script>
		<script is:inline>
			(() => {
				const root = document.documentElement;
				const toggle = document.querySelector('[data-drawer-toggle]');
				const closeButtons = document.querySelectorAll('[data-drawer-close]');
				const sidebar = document.querySelector('#site-sidebar');
				const links = sidebar?.querySelectorAll('a') ?? [];

				const setDrawer = (isOpen) => {
					root.dataset.drawer = isOpen ? 'open' : 'closed';
					document.body.style.overflow = isOpen ? 'hidden' : '';
					toggle?.setAttribute('aria-expanded', String(isOpen));
					toggle?.setAttribute('aria-label', isOpen ? closeNavLabel : openNavLabel);
				};

				toggle?.addEventListener('click', () => {
					setDrawer(root.dataset.drawer !== 'open');
				});

				closeButtons.forEach((button) => {
					button.addEventListener('click', () => setDrawer(false));
				});

				links.forEach((link) => {
					link.addEventListener('click', () => setDrawer(false));
				});

				window.addEventListener('keydown', (event) => {
					if (event.key === 'Escape') {
						setDrawer(false);
					}
				});

				window.matchMedia('(min-width: 821px)').addEventListener('change', (event) => {
					if (event.matches) {
						setDrawer(false);
					}
				});
			})();
		</script>
		<script is:inline>
			(() => {
				const buttons = document.querySelectorAll('[data-copy-email]');

				buttons.forEach((button) => {
					button.addEventListener('click', async () => {
						if (!(button instanceof HTMLElement)) return;

						const email = button.dataset.copyEmail;
						const defaultLabel = button.dataset.copyLabel ?? 'Gmail';
						const doneLabel = button.dataset.copyDone ?? 'Copied';
						const text = button.querySelector('[data-copy-text]');

						if (!email || !(text instanceof HTMLElement)) return;

						try {
							await navigator.clipboard.writeText(email);
							text.textContent = doneLabel;
							window.setTimeout(() => {
								text.textContent = defaultLabel;
							}, 1600);
						} catch {
							text.textContent = email;
							window.setTimeout(() => {
								text.textContent = defaultLabel;
							}, 2000);
						}
					});
				});
			})();
		</script>
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		--ink: #202327;
		--muted: #6b7280;
		--line: #e5e7eb;
		--paper: #f3f5f8;
		--panel: #ffffff;
		--button-bg: #ffffff;
		--button-hover: #f8fafc;
		--sidebar: #14181f;
		--sidebar-soft: #1d232d;
		--sidebar-text: #c8d0dc;
		--sidebar-strong: #ffffff;
		--wash: #f8fafc;
		--shadow: rgba(32, 35, 39, 0.06);
		--tag-bg: rgba(255, 255, 255, 0.7);
		--coral: #e65f4c;
		--teal: #009688;
		--leaf: #4d7c0f;
		--violet: #6d5bd0;
		--gold: #b7791f;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
	}

	html[data-theme="dark"] {
		color-scheme: dark;
		--ink: #e8eaed;
		--muted: #a8b0bb;
		--line: #2c333d;
		--paper: #101214;
		--panel: #181b1f;
		--button-bg: #20242a;
		--button-hover: #262b32;
		--sidebar: #090b0d;
		--sidebar-soft: #171b20;
		--sidebar-text: #aeb7c2;
		--sidebar-strong: #ffffff;
		--wash: #20242a;
		--shadow: rgba(0, 0, 0, 0.24);
		--tag-bg: rgba(255, 255, 255, 0.06);
	}

	* {
		box-sizing: border-box;
	}

	html {
		background: var(--paper);
		color: var(--ink);
	}

	body {
		margin: 0;
		min-width: 320px;
	}

	a {
		color: inherit;
		text-decoration-color: rgba(0, 121, 107, 0.38);
		text-underline-offset: 0.18em;
	}

	img {
		display: block;
		max-width: 100%;
	}

		.admin-shell {
			display: grid;
			grid-template-columns: 232px minmax(0, 1fr);
			min-height: 100vh;
			background: var(--paper);
		}

		.drawer-backdrop {
			display: none;
		}

		.sidebar {
			position: sticky;
			top: 0;
			height: 100vh;
			overflow-y: auto;
			background: var(--sidebar);
			box-shadow: 2px 0 10px var(--shadow);
		}

	.brand {
		display: flex;
		align-items: center;
		gap: 10px;
		height: 56px;
		padding: 0 18px;
		color: var(--sidebar-strong);
		font-weight: 800;
		text-decoration: none;
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}

	.brand-avatar {
		width: 28px;
		height: 28px;
		border: 1px solid rgba(0, 150, 136, 0.45);
		border-radius: 8px;
		object-fit: cover;
	}

	nav {
		padding: 12px 0;
	}

	nav a {
		display: flex;
		align-items: center;
		gap: 11px;
		min-height: 44px;
		padding: 0 18px;
		color: var(--sidebar-text);
		font-size: 0.94rem;
		font-weight: 650;
		text-decoration: none;
		border-left: 3px solid transparent;
	}

	.nav-icon {
		flex: 0 0 auto;
		width: 20px;
		color: #95a3b8;
	}

	nav a[aria-current="page"],
	nav a:hover {
		background: var(--sidebar-soft);
		color: var(--sidebar-strong);
		border-left-color: var(--teal);
	}

	.workbench {
		min-width: 0;
	}

	.topbar {
		position: sticky;
		top: 0;
		z-index: 4;
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 18px;
			min-height: 56px;
			padding: 0 22px;
			background: var(--panel);
			border-bottom: 1px solid var(--line);
			box-shadow: 0 1px 4px var(--shadow);
		}

		.topbar-primary {
			display: flex;
			align-items: center;
			min-width: 0;
			gap: 12px;
		}

		.menu-toggle {
			display: none;
			align-items: center;
			justify-content: center;
			flex: 0 0 auto;
			width: 40px;
			height: 40px;
			padding: 0;
			border: 1px solid var(--line);
			border-radius: 8px;
			background: var(--button-bg);
			color: var(--ink);
			cursor: pointer;
		}

		.menu-toggle:hover {
			background: var(--button-hover);
			color: var(--teal);
		}

		.breadcrumb {
			display: flex;
			align-items: center;
			flex-wrap: wrap;
			gap: 9px;
			color: var(--muted);
			font-size: 0.94rem;
		}

	.breadcrumb span:last-of-type {
		color: var(--ink);
		font-weight: 700;
	}

	.breadcrumb b {
		color: #b5bdc9;
		font-weight: 500;
	}

	.social-nav {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		flex-wrap: wrap;
		gap: 8px;
		padding: 0;
	}

	.top-actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		flex-wrap: wrap;
		gap: 8px;
	}

	.social-nav a,
	.social-button,
	.lang-toggle,
	.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 7px;
		min-height: 32px;
		padding: 0 10px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--button-bg);
		color: var(--muted);
		font: inherit;
		font-size: 0.87rem;
		font-weight: 700;
		text-decoration: none;
	}

	.social-button {
		cursor: pointer;
	}

	.lang-toggle,
	.theme-toggle {
		cursor: pointer;
	}

	.social-nav a:hover,
	.social-button:hover,
	.lang-toggle:hover,
	.theme-toggle:hover {
		background: var(--button-hover);
		color: var(--teal);
		border-left-color: var(--line);
	}

	.theme-icon-dark {
		display: none;
	}

	html[data-theme="dark"] .theme-icon-light {
		display: none;
	}

	html[data-theme="dark"] .theme-icon-dark {
		display: block;
	}

	main {
		display: flex;
		flex-direction: column;
		min-height: calc(100dvh - 56px);
		padding: 18px;
	}

	:global(.eyebrow) {
		margin: 0 0 8px;
		color: var(--teal);
		font-size: 0.86rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	:global(.page-title) {
		max-width: 820px;
		margin: 0;
		font-size: 1.55rem;
		line-height: 1.25;
		letter-spacing: 0;
	}

	:global(.lede) {
		max-width: 100%;
		margin: 10px 0 0;
		color: var(--muted);
		font-size: 0.98rem;
		line-height: 1.75;
	}

	:global(.section-head) {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 20px;
		margin: 20px 0 12px;
	}

	:global(.section-head h2) {
		margin: 0;
		font-size: 1.55rem;
	}

	:global(.section-head a) {
		color: var(--teal);
		font-weight: 750;
	}

	:global(.grid) {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(min(100%, 220px), 300px));
		justify-content: start;
		gap: 16px;
	}

	:global(.collection-toolbar) {
		display: flex;
		justify-content: flex-end;
		margin: -4px 0 16px;
	}

	:global(.entry-grid) {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(min(100%, 220px), 300px));
		justify-content: start;
		gap: 16px;
	}

	:global(.grid > .card),
	:global(.entry-grid > .entry-card) {
		width: 100%;
		max-width: 300px;
	}

	:global(.entry-list) {
		display: grid;
		gap: 12px;
	}

	:global(.collection-page) {
		display: flex;
		flex: 1 1 auto;
		flex-direction: column;
		min-height: max(420px, calc(100dvh - 280px));
	}

	:global(.collection-body) {
		flex: 0 0 auto;
		margin-bottom: 20px;
	}

	:global(.collection-page > .pagination-shell) {
		margin-top: auto;
	}

	:global(.tag-list) {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin: 14px 0 0;
		padding: 0;
		list-style: none;
	}

	:global(.tag-list li) {
		padding: 5px 8px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--tag-bg);
		color: var(--muted);
		font-size: 0.82rem;
	}

	:global(.prose) {
		max-width: 760px;
		padding: 20px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--panel);
	}

	:global(.prose p),
	:global(.prose li) {
		color: var(--ink);
		font-size: 1.02rem;
		line-height: 1.9;
	}

	:global(.prose h2) {
		margin-top: 34px;
	}

	@media (max-width: 820px) {
		.admin-shell {
			grid-template-columns: 1fr;
		}

		.drawer-backdrop {
			position: fixed;
			inset: 0;
			z-index: 9;
			display: block;
			border: 0;
			background: rgba(15, 23, 42, 0.48);
			opacity: 0;
			pointer-events: none;
			transition: opacity 160ms ease;
		}

		html[data-drawer="open"] .drawer-backdrop {
			opacity: 1;
			pointer-events: auto;
		}

		.sidebar {
			position: fixed;
			top: 0;
			left: 0;
			z-index: 10;
			width: min(304px, 84vw);
			height: 100vh;
			transform: translateX(-102%);
			transition: transform 180ms ease;
		}

		html[data-drawer="open"] .sidebar {
			transform: translateX(0);
		}

		.sidebar nav {
			display: block;
			padding: 12px 0;
		}

		.sidebar nav a {
			border-left: 3px solid transparent;
			border-radius: 0;
		}

		.topbar {
			position: sticky;
			align-items: stretch;
			flex-direction: column;
			gap: 10px;
			padding: 10px 12px;
		}

		.topbar-primary {
			width: 100%;
		}

		.menu-toggle {
			display: inline-flex;
		}

		.breadcrumb {
			min-width: 0;
			overflow: hidden;
			white-space: nowrap;
			flex-wrap: nowrap;
		}

		.breadcrumb span,
		.breadcrumb b {
			flex: 0 0 auto;
		}

		.breadcrumb span:last-of-type {
			overflow: hidden;
			text-overflow: ellipsis;
		}

		.top-actions {
			justify-content: flex-start;
			width: 100%;
			gap: 6px;
		}

		.social-nav {
			gap: 6px;
		}

		.social-nav a,
		.social-button {
			width: 36px;
			padding: 0;
		}

		.social-nav a span,
		.social-button span {
			position: absolute;
			width: 1px;
			height: 1px;
			overflow: hidden;
			clip: rect(0 0 0 0);
			white-space: nowrap;
		}

		:global(.page-title) {
			font-size: 1.35rem;
		}

		main {
			padding: 14px;
		}
	}

	@media (max-width: 820px) {
		:global(.collection-toolbar) {
			justify-content: flex-start;
		}

		:global(.grid),
		:global(.entry-grid) {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			justify-content: stretch;
		}

		:global(.grid > .card),
		:global(.entry-grid > .entry-card) {
			max-width: none;
		}
	}

	@media (max-width: 360px) {
		:global(.grid),
		:global(.entry-grid) {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 520px) {
		.lang-toggle span,
		.theme-toggle span {
			position: absolute;
