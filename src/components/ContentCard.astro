---
interface Props {
	href: string;
	title: string;
	summary: string;
	date?: Date;
	cover?: string;
	tags?: string[];
	accent?: 'coral' | 'teal' | 'leaf' | 'violet' | 'gold';
	meta?: string;
}

const {
	href,
	title,
	summary,
	date,
	cover,
	tags = [],
	accent = 'teal',
	meta,
} = Astro.props;

const formattedDate = date?.toLocaleDateString('zh-CN', {
	year: 'numeric',
	month: 'short',
	day: 'numeric',
});
---

<article class:list={['card', `accent-${accent}`]}>
	{
		cover && (
			<a class="cover" href={href} aria-label={title}>
				<img src={cover} alt="" loading="lazy" />
			</a>
		)
	}
	<div class="body">
		<p class="meta">{meta ?? formattedDate}</p>
		<h3><a href={href}>{title}</a></h3>
		<p>{summary}</p>
		{
			tags.length > 0 && (
				<ul class="tag-list">
					{tags.map((tag) => <li>{tag}</li>)}
				</ul>
			)
		}
	</div>
</article>

<style>
	.card {
		display: grid;
		overflow: hidden;
		min-height: 100%;
		border: 1px solid var(--line);
		border-top: 5px solid var(--teal);
		border-radius: 8px;
		background: var(--panel);
		box-shadow: 0 2px 10px rgba(32, 35, 39, 0.04);
	}

	.accent-coral {
		border-top-color: var(--coral);
	}

	.accent-leaf {
		border-top-color: var(--leaf);
	}

	.accent-violet {
		border-top-color: var(--violet);
	}

	.accent-gold {
		border-top-color: var(--gold);
	}

	.cover {
		aspect-ratio: 16 / 9;
		background: var(--wash);
	}

	.cover img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.body {
		padding: 18px;
	}

	.meta {
		margin: 0 0 10px;
		color: var(--muted);
		font-size: 0.85rem;
	}

	h3 {
		margin: 0;
		font-size: 1.18rem;
		line-height: 1.35;
	}

	h3 a {
		text-decoration: none;
	}

	.body > p:last-of-type {
		margin: 10px 0 0;
		color: var(--muted);
		line-height: 1.7;
	}
</style>
