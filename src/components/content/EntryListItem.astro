---
import type { Lang } from '../../lib/i18n';
import { localizePath, t } from '../../lib/i18n';
import TagBadge from './TagBadge.astro';

interface Props {
	item: any;
	collection: 'academic' | 'notes';
	lang: Lang;
}

const { item, collection, lang } = Astro.props;
const { entry, baseId, isFallback } = item;
const href = localizePath(`/${collection}/${baseId}/`, lang);
const date = entry.data.date.toLocaleDateString(lang === 'en' ? 'en-US' : 'zh-CN');
---

<article class="entry-row">
	<div class="date">{date}</div>
	<div class="content">
		<div class="title-line">
			<h2><a href={href}>{entry.data.title}</a></h2>
			{isFallback && <span class="fallback">{t(lang, 'chineseOnly')}</span>}
		</div>
		<p>{entry.data.summary}</p>
		{
			entry.data.tags.length > 0 && (
				<div class="tags">
					{entry.data.tags.map((tag: string) => <TagBadge tag={tag} collection={collection} lang={lang} />)}
				</div>
			)
		}
	</div>
</article>

<style>
	.entry-row {
		display: grid;
		grid-template-columns: 132px minmax(0, 1fr);
		gap: 18px;
		padding: 18px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--panel);
		box-shadow: 0 2px 10px var(--shadow);
	}

	.date {
		color: var(--muted);
		font-size: 0.88rem;
		font-weight: 750;
	}

	.title-line {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 8px;
	}

	h2 {
		margin: 0;
		font-size: 1.04rem;
		line-height: 1.35;
	}

	h2 a {
		text-decoration: none;
	}

	.fallback {
		padding: 2px 7px;
		border: 1px solid var(--line);
		border-radius: 8px;
		color: var(--teal);
		font-size: 0.78rem;
		font-weight: 800;
	}

	p {
		margin: 8px 0 0;
		color: var(--muted);
		line-height: 1.68;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: 12px;
	}

	@media (max-width: 620px) {
		.entry-row {
			grid-template-columns: 1fr;
			gap: 10px;
			padding: 16px;
		}
	}
</style>
