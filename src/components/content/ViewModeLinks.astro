---
import type { Lang } from '../../lib/i18n';
import { localizePath, t } from '../../lib/i18n';

interface Props {
	basePath: string;
	active: 'card' | 'list';
	lang: Lang;
}

const { basePath, active, lang } = Astro.props;
const cardHref = localizePath(`${basePath}/`, lang);
const listHref = localizePath(`${basePath}/list/`, lang);
---

<div class="view-links" aria-label="视图切换">
	<a href={cardHref} aria-current={active === 'card' ? 'page' : undefined}>{t(lang, 'cardView')}</a>
	<a href={listHref} aria-current={active === 'list' ? 'page' : undefined}>{t(lang, 'listView')}</a>
</div>

<style>
	.view-links {
		display: inline-flex;
		gap: 8px;
	}

	.view-links a {
		display: inline-flex;
		align-items: center;
		min-height: 34px;
		padding: 0 11px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--button-bg);
		color: var(--muted);
		font-size: 0.88rem;
		font-weight: 800;
		text-decoration: none;
	}

	.view-links a[aria-current="page"],
	.view-links a:hover {
		color: var(--teal);
		background: var(--button-hover);
	}
</style>
