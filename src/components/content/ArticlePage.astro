---
import type { Lang } from '../../lib/i18n';
import { t } from '../../lib/i18n';
import TagBadge from './TagBadge.astro';

interface Props {
	title: string;
	summary: string;
	date: Date;
	collection: 'academic' | 'notes';
	lang: Lang;
	tags?: string[];
	isFallback?: boolean;
	eyebrow?: string;
}

const {
	title,
	summary,
	date,
	collection,
	lang,
	tags = [],
	isFallback = false,
	eyebrow = collection === 'academic' ? t(lang, 'academicEyebrow') : t(lang, 'notesEyebrow'),
} = Astro.props;

const formattedDate = date.toLocaleDateString(lang === 'en' ? 'en-US' : 'zh-CN');
---

<article class="article-shell">
	<header class="article-head">
		<p class="eyebrow">{eyebrow}</p>
		<h1>{title}</h1>
		<p class="summary">{summary}</p>
		<div class="article-meta">
			<span>{formattedDate}</span>
			{isFallback && <span class="fallback">{t(lang, 'chineseOnly')}</span>}
			{tags.map((tag) => <TagBadge tag={tag} collection={collection} lang={lang} />)}
		</div>
	</header>
	<div class="article-prose">
		<slot />
	</div>
</article>

<style>
	.article-shell {
		width: min(100%, 920px);
		margin: 0 auto;
	}

	.article-head {
		padding: 10px 0 22px;
		border-bottom: 1px solid var(--line);
	}

	.eyebrow {
		margin: 0 0 10px;
		color: var(--teal);
		font-size: 0.86rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	h1 {
		max-width: 820px;
		margin: 0;
		color: var(--ink);
		font-size: 2rem;
		line-height: 1.22;
		letter-spacing: 0;
	}

	.summary {
		max-width: 760px;
		margin: 14px 0 0;
		color: var(--muted);
		font-size: 1rem;
		line-height: 1.78;
	}

	.article-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 8px;
		margin-top: 16px;
		color: var(--muted);
		font-size: 0.88rem;
		font-weight: 750;
	}

	.fallback {
		padding: 3px 8px;
		border: 1px solid var(--line);
		border-radius: 8px;
		color: var(--teal);
		font-weight: 800;
	}

	.article-prose {
		padding: 24px 0 42px;
	}

	.article-prose :global(*) {
		max-width: 100%;
	}

	.article-prose :global(p),
	.article-prose :global(li) {
		color: var(--ink);
		font-size: 1.02rem;
		line-height: 1.92;
	}

	.article-prose :global(p) {
		margin: 0 0 18px;
	}

	.article-prose :global(h2),
	.article-prose :global(h3),
	.article-prose :global(h4) {
		color: var(--ink);
		line-height: 1.35;
		letter-spacing: 0;
	}

	.article-prose :global(h2) {
		margin: 34px 0 14px;
		font-size: 1.42rem;
	}

	.article-prose :global(h3) {
		margin: 28px 0 12px;
		font-size: 1.18rem;
	}

	.article-prose :global(ul),
	.article-prose :global(ol) {
		margin: 0 0 18px;
		padding-left: 1.35rem;
	}

	.article-prose :global(img) {
		display: block;
		width: auto;
		max-width: 100%;
		max-height: 620px;
		margin: 22px auto;
		border: 1px solid var(--line);
		border-radius: 8px;
		object-fit: contain;
		box-shadow: 0 2px 10px var(--shadow);
	}

	.article-prose :global(blockquote) {
		margin: 22px 0;
		padding: 12px 16px;
		border-left: 4px solid var(--teal);
		background: var(--wash);
		color: var(--muted);
	}

	.article-prose :global(code) {
		padding: 2px 5px;
		border: 1px solid var(--line);
		border-radius: 6px;
		background: var(--wash);
		font-size: 0.92em;
	}

	.article-prose :global(pre) {
		overflow-x: auto;
		margin: 22px 0;
		padding: 16px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--wash);
	}

	.article-prose :global(pre code) {
		padding: 0;
		border: 0;
		background: transparent;
	}

	@media (max-width: 620px) {
		.article-head {
			padding-top: 4px;
			padding-bottom: 18px;
		}

		h1 {
			font-size: 1.55rem;
		}

		.article-prose {
			padding-top: 20px;
		}
	}

	@media (min-width: 1280px) {
		.article-shell {
			width: min(100%, 72vw, 1120px);
		}
	}

	@media (min-width: 1800px) {
		.article-shell {
			width: min(100%, 66vw, 1280px);
		}
	}
</style>
