---
import type { Lang } from '../../lib/i18n';
import { localizePath, t } from '../../lib/i18n';
import TagBadge from './TagBadge.astro';

interface Props {
	item: any;
	collection: 'academic' | 'notes';
	lang: Lang;
}

const { item, collection, lang } = Astro.props;
const { entry, baseId, isFallback } = item;
const href = localizePath(`/${collection}/${baseId}/`, lang);
const date = entry.data.date.toLocaleDateString(lang === 'en' ? 'en-US' : 'zh-CN');
---

<article class="entry-card">
	{
		entry.data.cover && (
			<a class="cover" href={href} aria-label={entry.data.title}>
				<img src={entry.data.cover} alt="" loading="lazy" />
			</a>
		)
	}
	<div class="body">
		<div class="meta">
			<span>{date}</span>
			{isFallback && <span class="fallback">{t(lang, 'chineseOnly')}</span>}
		</div>
		<h2><a href={href}>{entry.data.title}</a></h2>
		<p>{entry.data.summary}</p>
		{
			entry.data.tags.length > 0 && (
				<div class="tags">
					{entry.data.tags.map((tag: string) => <TagBadge tag={tag} collection={collection} lang={lang} />)}
				</div>
			)
		}
	</div>
</article>

<style>
	.entry-card {
		display: grid;
		overflow: hidden;
		min-height: 100%;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--panel);
		box-shadow: 0 2px 10px var(--shadow);
	}

	.cover {
		aspect-ratio: 16 / 9;
		background: var(--wash);
	}

	.cover img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.body {
		padding: 14px;
	}

	.meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 8px;
		margin-bottom: 10px;
		color: var(--muted);
		font-size: 0.85rem;
	}

	.fallback {
		padding: 2px 7px;
		border: 1px solid var(--line);
		border-radius: 8px;
		color: var(--teal);
		font-weight: 800;
	}

	h2 {
		margin: 0;
		font-size: 1.02rem;
		line-height: 1.4;
	}

	h2 a {
		text-decoration: none;
	}

	p {
		margin: 10px 0 0;
		color: var(--muted);
		font-size: 0.92rem;
		line-height: 1.72;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: 12px;
	}

	@media (max-width: 620px) {
		.body {
			padding: 15px;
		}

		h2 {
			font-size: 1.06rem;
		}
	}
</style>
