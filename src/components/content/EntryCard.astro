---
import type { Lang } from '../../lib/i18n';
import { localizePath, t } from '../../lib/i18n';
import type { LocalizedItem } from '../../lib/content';
import TagBadge from './TagBadge.astro';

interface Props {
	item: LocalizedItem<'academic'> | LocalizedItem<'notes'>;
	collection: 'academic' | 'notes';
	lang: Lang;
}

const { item, collection, lang } = Astro.props;
const { entry, baseId, isFallback } = item;
const href = localizePath(`/${collection}/${baseId}/`, lang);
const date = entry.data.date.toLocaleDateString(lang === 'en' ? 'en-US' : 'zh-CN');
const cardTags = entry.data.tags.slice(0, 2);
---

<article class="entry-card">
	{entry.data.pinned && <span class="card-pinned">{t(lang, 'pinnedBadge')}</span>}
	{
		entry.data.cover && (
			<a class="cover" href={href} aria-label={entry.data.title}>
				<img src={entry.data.cover} alt="" loading="lazy" />
			</a>
		)
	}
	<div class="body">
		<div class="meta">
			<span>{date}</span>
			{isFallback && <span class="fallback">{t(lang, 'chineseOnly')}</span>}
		</div>
		<h2><a href={href}>{entry.data.title}</a></h2>
		<p>{entry.data.summary}</p>
		{
			cardTags.length > 0 && (
				<div class="tags">
					{cardTags.map((tag: string) => <TagBadge tag={tag} collection={collection} lang={lang} />)}
				</div>
			)
		}
	</div>
</article>

<style>
	.entry-card {
		position: relative;
		display: grid;
		grid-template-rows: auto 1fr;
		overflow: hidden;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--panel);
		box-shadow: 0 2px 10px var(--shadow);
	}

	.cover {
		aspect-ratio: 16 / 9;
		background: var(--wash);
	}

	.cover img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.body {
		display: flex;
		min-width: 0;
		flex-direction: column;
		gap: 10px;
		padding: 14px;
	}

	.meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 8px;
		color: var(--muted);
		font-size: 0.85rem;
	}

	.fallback {
		padding: 2px 7px;
		border: 1px solid var(--line);
		border-radius: 8px;
		color: var(--teal);
		font-weight: 800;
	}

	.card-pinned {
		position: absolute;
		top: 10px;
		left: 10px;
		z-index: 2;
		padding: 4px 9px;
		border: 1px solid rgba(13, 148, 136, 0.34);
		border-radius: 8px;
		color: white;
		background: rgba(13, 148, 136, 0.82);
		backdrop-filter: blur(6px);
		font-size: 0.76rem;
		font-weight: 800;
		line-height: 1;
	}

	h2 {
		margin: 0;
		font-size: 1.02rem;
		line-height: 1.4;
		overflow: hidden;
		white-space: nowrap;
		text-overflow: ellipsis;
	}

	h2 a {
		display: block;
		overflow: hidden;
		white-space: nowrap;
		text-overflow: ellipsis;
		text-decoration: none;
	}

	p {
		margin: 0;
		color: var(--muted);
		font-size: 0.92rem;
		line-height: 1.72;
		display: -webkit-box;
		overflow: hidden;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
		text-wrap: pretty;
		overflow-wrap: break-word;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: auto;
		align-content: flex-start;
	}

	@media (max-width: 620px) {
		.body {
			padding: 15px;
		}

		h2 {
			font-size: 1.06rem;
		}
	}
</style>
