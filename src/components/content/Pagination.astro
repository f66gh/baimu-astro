---
import type { Lang } from '../../lib/i18n';
import { localizePath, t } from '../../lib/i18n';

interface Props {
	basePath: string;
	currentPage: number;
	totalPages: number;
	lang: Lang;
}

const { basePath, currentPage, totalPages, lang } = Astro.props;

function pageHref(page: number) {
	const path = page === 1 ? `${basePath}/` : `${basePath}/page/${page}/`;
	return localizePath(path, lang);
}

const pages = Array.from({ length: totalPages }, (_, index) => index + 1);
---

<nav class="pagination-shell" aria-label={t(lang, 'paginationNav')}>
	<div class="pagination">
		<a href={pageHref(Math.max(1, currentPage - 1))} aria-disabled={currentPage === 1 ? 'true' : undefined}>
			{t(lang, 'previous')}
		</a>
		{
			pages.map((page) => (
				<a href={pageHref(page)} aria-current={page === currentPage ? 'page' : undefined}>
					{page}
				</a>
			))
		}
		<a href={pageHref(Math.min(totalPages, currentPage + 1))} aria-disabled={currentPage === totalPages ? 'true' : undefined}>
			{t(lang, 'next')}
		</a>
	</div>
	<p>{t(lang, 'pageStatus', { current: currentPage, total: totalPages })}</p>
</nav>

<style>
	.pagination-shell {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-direction: column;
		gap: 10px;
		margin-top: 20px;
		padding: 14px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--panel);
		box-shadow: 0 2px 10px var(--shadow);
	}

	.pagination-shell p {
		margin: 0;
		color: var(--muted);
		font-size: 0.9rem;
		font-weight: 800;
	}

	.pagination {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 8px;
	}

	.pagination a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 36px;
		min-height: 36px;
		padding: 0 10px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--button-bg);
		color: var(--muted);
		font-weight: 800;
		text-decoration: none;
	}

	.pagination a[aria-current="page"],
	.pagination a:hover {
		color: var(--teal);
		background: var(--button-hover);
	}

	.pagination a[aria-disabled="true"] {
		pointer-events: none;
		opacity: 0.45;
	}

	@media (max-width: 620px) {
		.pagination {
			width: 100%;
		}
	}
</style>
