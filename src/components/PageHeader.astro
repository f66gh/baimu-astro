---
interface Props {
	eyebrow: string;
	title: string;
	lede: string;
}

const { eyebrow, title, lede } = Astro.props;
---

<section class="page-hero">
	<p class="eyebrow">{eyebrow}</p>
	<h1 class="page-title">{title}</h1>
	<p class="lede">{lede}</p>
</section>

<style>
	.page-hero {
		margin-bottom: 16px;
		padding: 20px 22px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--panel);
		box-shadow: 0 2px 10px rgba(32, 35, 39, 0.04);
	}
</style>
