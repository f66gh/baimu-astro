---
import type { Lang } from '../../lib/i18n';
import { localizePath, t } from '../../lib/i18n';
import type { LocalizedItem } from '../../lib/content';
import { getAnimeSeason, getRewatchBucket, getRewatchLabel } from '../../lib/anime';
import TagBadge from '../content/TagBadge.astro';
import AnimeRating from './AnimeRating.astro';

interface Props {
	item: LocalizedItem<'anime'>;
	lang?: Lang;
}

const { item, lang = 'zh' } = Astro.props;
const { entry, baseId, isFallback } = item;
const season = getAnimeSeason(entry.data.date, lang);
const rewatchBucket = getRewatchBucket(entry.data.rewatchCount);
const tags = (entry.data.tags ?? []).filter((tag) => tag.trim().length > 0);
const moods = (entry.data.moods ?? []).filter((mood) => mood.trim().length > 0);
const filterTags = tags.join('|');
const href = localizePath(`/anime/${baseId}/`, lang);
---

<article
	class="anime-list-item"
	data-anime-entry
	data-anime-card
	data-season={season.value}
	data-rating={entry.data.rating ?? ''}
	data-rewatch={rewatchBucket}
	data-tags={filterTags}
>
	<a class="thumb" href={href} aria-label={entry.data.title}>
		{
			entry.data.cover ? (
				<img src={entry.data.cover} alt="" loading="lazy" />
			) : (
				<span>{entry.data.title.slice(0, 2)}</span>
			)
		}
	</a>
	<div class="content">
		<div class="meta-line">
			<span>{season.label}</span>
			<span>{entry.data.date.toLocaleDateString(lang === 'en' ? 'en-US' : 'zh-CN')}</span>
			<span>{getRewatchLabel(entry.data.rewatchCount, lang)}</span>
			{entry.data.pinned && <span class="pinned">{t(lang, 'pinnedBadge')}</span>}
			{isFallback && lang === 'en' && <span class="fallback">{t(lang, 'onlyChineseCard')}</span>}
		</div>
		<h2><a href={href}>{entry.data.title}</a></h2>
		<AnimeRating rating={entry.data.rating} lang={lang} />
		<p>{entry.data.summary}</p>
		{
			(tags.length > 0 || moods.length > 0) && (
				<div class="tags">
					{tags.map((tag: string) => <TagBadge tag={tag} collection="anime" lang={lang} />)}
					{moods.map((mood: string) => <TagBadge tag={mood} collection="anime" lang={lang} />)}
				</div>
			)
		}
	</div>
</article>

<style>
	.anime-list-item {
		display: grid;
		grid-template-columns: 96px minmax(0, 1fr);
		gap: 16px;
		padding: 14px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--panel);
		box-shadow: 0 2px 10px var(--shadow);
	}

	.thumb {
		display: grid;
		place-items: center;
		overflow: hidden;
		aspect-ratio: 2 / 3;
		border-radius: 8px;
		background: var(--wash);
		color: var(--teal);
		font-size: 1.2rem;
		font-weight: 900;
		text-decoration: none;
	}

	.thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.content {
		min-width: 0;
	}

	.meta-line {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		color: var(--muted);
		font-size: 0.78rem;
		font-weight: 800;
	}

	.fallback {
		padding: 2px 7px;
		border: 1px solid var(--line);
		border-radius: 8px;
		color: var(--teal);
		background: var(--tag-bg);
	}

	.pinned {
		padding: 2px 7px;
		border: 1px solid color-mix(in srgb, var(--teal) 42%, var(--line));
		border-radius: 8px;
		color: var(--teal);
		background: color-mix(in srgb, var(--teal) 12%, transparent);
	}

	h2 {
		margin: 6px 0 6px;
		font-size: 1.05rem;
		line-height: 1.35;
	}

	h2 a {
		text-decoration: none;
	}

	p {
		margin: 8px 0 0;
		color: var(--muted);
		line-height: 1.68;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: 12px;
	}

	@media (max-width: 560px) {
		.anime-list-item {
			grid-template-columns: 72px minmax(0, 1fr);
			gap: 12px;
			padding: 12px;
		}
	}
</style>
