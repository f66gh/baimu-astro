---
import type { Lang } from '../../lib/i18n';
import { t } from '../../lib/i18n';
import type { LocalizedItem } from '../../lib/content';
import { getAnimeSeason } from '../../lib/anime';
import AnimeCard from './AnimeCard.astro';
import AnimeFilterBar from './AnimeFilterBar.astro';
import PageHeader from '../PageHeader.astro';

interface Option {
	value: string;
	label: string;
}

interface Props {
	entries: LocalizedItem<'anime'>[];
	filterEntries: LocalizedItem<'anime'>[];
	lang?: Lang;
}

const { entries, filterEntries, lang = 'zh' } = Astro.props;

const seasonMap = new Map();

filterEntries.forEach((item) => {
	const { entry } = item;
	const season = getAnimeSeason(entry.data.date, lang);
	seasonMap.set(season.value, season);
});

const seasons: Option[] = Array.from(seasonMap.values())
	.sort((a, b) => b.sort - a.sort)
	.map((season) => ({ value: season.value, label: season.label }));
---

<PageHeader eyebrow={t(lang, 'animeEyebrow')} title={t(lang, 'animeTitle')} lede={t(lang, 'animeLede')}>
	<AnimeFilterBar seasons={seasons} lang={lang} />
</PageHeader>

<section class="anime-wall" aria-label={t(lang, 'animeWallLabel')}>
	{entries.map((item) => <AnimeCard item={item} lang={lang} />)}
</section>

<style>
	.anime-wall {
		--anime-card-width: 188px;
		--anime-poster-height: calc(var(--anime-card-width) * 1.5);
		--anime-card-height: calc(var(--anime-poster-height) + 84px);

		display: grid;
		grid-template-columns: repeat(auto-fill, var(--anime-card-width));
		align-items: start;
		justify-content: start;
		gap: 18px;
		min-height: max(360px, calc(100dvh - 350px));
		perspective: 1100px;
	}

	@media (min-width: 1480px) {
		.anime-wall {
			gap: 20px;
		}
	}

	@media (max-width: 760px) {
		.anime-wall {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			justify-content: stretch;
			gap: 12px;
			min-height: auto;
		}
	}

	@media (max-width: 360px) {
		.anime-wall {
			grid-template-columns: 1fr;
		}
	}
</style>
