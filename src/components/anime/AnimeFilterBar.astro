---
import type { Lang } from '../../lib/i18n';
import { t } from '../../lib/i18n';

interface Option {
	value: string;
	label: string;
}

interface Props {
	seasons: Option[];
	lang?: Lang;
}

const { seasons, lang = 'zh' } = Astro.props;

const rewatchOptions = [
	{ value: 'first', label: t(lang, 'firstWatch') },
	{ value: 'rewatch', label: t(lang, 'rewatchShort') },
];

const countTemplate = t(lang, 'showingCount', { visible: '{visible}', total: '{total}' });
---

<section class="anime-filter" aria-label={t(lang, 'animeFilterLabel')} data-count-template={countTemplate}>
	<div class="filter-group season-filter" data-filter-group="season">
		<span>{t(lang, 'watchTime')}</span>
		<button type="button" data-filter-value="all" aria-pressed="true">{t(lang, 'all')}</button>
		{seasons.map((option) => (
			<button type="button" data-filter-value={option.value} aria-pressed="false">{option.label}</button>
		))}
	</div>
	<div class="sort-buttons" aria-label={t(lang, 'animeSortLabel')}>
		<button type="button" data-sort-value="date-desc" aria-pressed="true">{t(lang, 'sortDateDesc')}</button>
		<button type="button" data-sort-value="date-asc" aria-pressed="false">{t(lang, 'sortDateAsc')}</button>
		<button type="button" data-sort-value="rating-desc" aria-pressed="false">{t(lang, 'sortRatingDesc')}</button>
		<button type="button" data-sort-value="rating-asc" aria-pressed="false">{t(lang, 'sortRatingAsc')}</button>
	</div>
	<div class="filter-group rewatch-filter" data-filter-group="rewatch">
		<span>{t(lang, 'rewatch')}</span>
		<button type="button" data-filter-value="all" aria-pressed="true">{t(lang, 'all')}</button>
		{rewatchOptions.map((option) => (
			<button type="button" data-filter-value={option.value} aria-pressed="false">{option.label}</button>
		))}
	</div>
	<p class="filter-count" data-filter-count></p>
</section>

	<script>
		(() => {
			const root = document.querySelector('.anime-filter');
			const wall = document.querySelector('.anime-wall');
			const cards = Array.from((wall ?? document).querySelectorAll('[data-anime-entry]'));
			const count = document.querySelector('[data-filter-count]');
			const sortButtons = Array.from(root?.querySelectorAll('button[data-sort-value]') ?? []);
			const seasonButtons = Array.from(root?.querySelectorAll('.season-filter button[data-filter-value]') ?? []);
			const rewatchButtons = Array.from(root?.querySelectorAll('.rewatch-filter button[data-filter-value]') ?? []);

			if (!root || !wall || cards.length === 0) return;

			const countTemplate = root.dataset.countTemplate ?? 'Showing {visible} / {total}';
			const params = new URLSearchParams(window.location.search);
			const validSeasons = new Set(['all', ...seasonButtons.map((button) => button.dataset.filterValue ?? 'all')]);
			const validRewatch = new Set(['all', 'first', 'rewatch']);
			const validSorts = new Set(['date-desc', 'date-asc', 'rating-desc', 'rating-asc']);
			const state = {
				season: validSeasons.has(params.get('season') ?? '') ? (params.get('season') ?? 'all') : 'all',
				rewatch: validRewatch.has(params.get('rewatch') ?? '') ? (params.get('rewatch') ?? 'all') : 'all',
				sort: validSorts.has(params.get('sort') ?? '') ? (params.get('sort') ?? 'date-desc') : 'date-desc',
			};

			const matches = (card) => {
			const dataset = card.dataset;

			return (
				(state.season === 'all' || dataset.season === state.season) &&
				(state.rewatch === 'all' || dataset.rewatch === state.rewatch)
				);
			};

			const syncUrl = () => {
				const next = new URL(window.location.href);
				const nextParams = next.searchParams;

				if (state.season === 'all') nextParams.delete('season');
				else nextParams.set('season', state.season);

				if (state.rewatch === 'all') nextParams.delete('rewatch');
				else nextParams.set('rewatch', state.rewatch);

				if (state.sort === 'date-desc') nextParams.delete('sort');
				else nextParams.set('sort', state.sort);

				const nextSearch = nextParams.toString();
				const nextUrl = `${next.pathname}${nextSearch ? `?${nextSearch}` : ''}${next.hash}`;
				window.history.replaceState({}, '', nextUrl);
			};

			const syncPressed = () => {
				sortButtons.forEach((button) => {
					button.setAttribute('aria-pressed', String((button.dataset.sortValue ?? 'date-desc') === state.sort));
				});

				seasonButtons.forEach((button) => {
					button.setAttribute('aria-pressed', String((button.dataset.filterValue ?? 'all') === state.season));
				});

				rewatchButtons.forEach((button) => {
					button.setAttribute('aria-pressed', String((button.dataset.filterValue ?? 'all') === state.rewatch));
				});
			};

			const sortCards = () => {
				const sorted = [...cards].sort((left, right) => {
					const leftDate = Number(left.dataset.date ?? 0);
					const rightDate = Number(right.dataset.date ?? 0);
					const leftRating = Number(left.dataset.rating ?? 0);
					const rightRating = Number(right.dataset.rating ?? 0);
					const leftPinned = Number(left.dataset.pinned ?? 0);
					const rightPinned = Number(right.dataset.pinned ?? 0);
					const pinnedDiff = rightPinned - leftPinned;

					if (pinnedDiff !== 0) return pinnedDiff;

					if (state.sort === 'date-asc') return leftDate - rightDate;
					if (state.sort === 'rating-desc') return rightRating - leftRating || rightDate - leftDate;
					if (state.sort === 'rating-asc') return leftRating - rightRating || rightDate - leftDate;
					return rightDate - leftDate;
				});

				sorted.forEach((card) => wall.append(card));
			};

			const applyFilters = () => {
			let visible = 0;

			sortCards();

			cards.forEach((card) => {
				const isVisible = matches(card);
				card.hidden = !isVisible;
				if (isVisible) visible += 1;
			});

			if (count) {
					count.textContent = countTemplate
						.replace('{visible}', String(visible))
						.replace('{total}', String(cards.length));
				}

				syncPressed();
				syncUrl();
			};

			root.addEventListener('click', (event) => {
			const target = event.target;
			if (!(target instanceof Element)) return;

				const sortButton = target.closest('button[data-sort-value]');
				if (sortButton) {
					state.sort = sortButton.dataset.sortValue ?? 'date-desc';
					applyFilters();
					return;
				}

			const button = target.closest('button[data-filter-value]');
			const group = button?.closest('[data-filter-group]');

			if (!button || !group) return;

			const key = group.dataset.filterGroup;
			const buttons = Array.from(group.querySelectorAll('button'));

				if (!key || !(key in state)) return;

				state[key] = button.dataset.filterValue ?? 'all';
				applyFilters();
			});

		applyFilters();
	})();
</script>

<style>
	.anime-filter {
		display: grid;
		grid-template-areas:
			"season sort"
			"rewatch count";
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 10px;
		align-items: center;
		margin: 18px 0 0;
		padding: 0;
		border-top: 1px solid var(--line);
		padding-top: 14px;
	}

	.filter-group {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 8px;
	}

	.filter-group > span {
		min-width: 68px;
		color: var(--ink);
		font-size: 0.82rem;
		font-weight: 850;
	}

	.season-filter {
		grid-area: season;
	}

	.rewatch-filter {
		grid-area: rewatch;
	}

	button {
		min-height: 28px;
		padding: 0 9px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--button-bg);
		color: var(--muted);
		font: inherit;
		font-size: 0.8rem;
		font-weight: 750;
		cursor: pointer;
	}

	button[aria-pressed="true"],
	button:hover {
		background: var(--button-hover);
		color: var(--teal);
	}

	.sort-buttons {
		grid-area: sort;
		display: flex;
		align-items: center;
		justify-content: flex-end;
		flex-wrap: nowrap;
		gap: 8px;
		white-space: nowrap;
	}

	.filter-count {
		grid-area: count;
		margin: 0;
		color: var(--muted);
		font-size: 0.8rem;
		font-weight: 750;
		text-align: right;
		white-space: nowrap;
	}

	:global(.anime-wall [hidden]) {
		display: none !important;
	}

	@media (max-width: 1100px) {
		.anime-filter {
			grid-template-areas:
				"season"
				"rewatch"
				"sort"
				"count";
			grid-template-columns: 1fr;
			align-items: start;
		}

		.sort-buttons,
		.filter-count {
			text-align: left;
		}

		.sort-buttons {
			justify-content: flex-start;
			flex-wrap: wrap;
			white-space: normal;
		}
	}

	@media (max-width: 620px) {
		.filter-group > span {
			width: 100%;
		}

		.sort-buttons {
			display: grid;
			grid-template-columns: 1fr 1fr;
			width: 100%;
			white-space: normal;
		}

		.sort-buttons button {
			width: 100%;
		}
	}
</style>
