---
import type { Lang } from '../../lib/i18n';
import { t } from '../../lib/i18n';
import type { LocalizedItem } from '../../lib/content';
import { getMusicTagHue } from '../../lib/music';

interface Props {
	item: LocalizedItem<'music'>;
	lang?: Lang;
}

const { item, lang = 'zh' } = Astro.props;
const { entry, isFallback } = item;
const tags = entry.data.tags ?? [];
const formats = entry.data.formats ?? [];
---

<article class="music-card music-album-card">
	<a class="card-link" href={entry.data.url} target="_blank" rel="noreferrer" aria-label={`${t(lang, 'openLink')} ${entry.data.title}`}>
		<div class="cover">
			{
				entry.data.cover ? (
					<img src={entry.data.cover} alt="" loading="lazy" />
				) : (
					<span>{entry.data.title.slice(0, 2)}</span>
				)
			}
		</div>
		<div class="body">
			<span class="meta">{entry.data.date.toLocaleDateString(lang === 'en' ? 'en-US' : 'zh-CN')}</span>
			<h3>{entry.data.title}</h3>
			{isFallback && lang === 'en' && <span class="fallback">{t(lang, 'onlyChineseCard')}</span>}
		</div>
		<div class="hover-panel">
			<span class="hover-label">{t(lang, 'openLink')}</span>
			<p>{entry.data.summary}</p>
			{
				formats.length > 0 && (
					<div class="formats">
						{formats.slice(0, 3).map((format: string) => <span style={`--tag-hue: ${getMusicTagHue(format)}`}>{format}</span>)}
					</div>
				)
			}
			{
				tags.length > 0 && (
					<div class="tags">
						{tags.slice(0, 3).map((tag: string) => <span>{tag}</span>)}
					</div>
				)
			}
		</div>
	</a>
</article>

<style>
	.music-card {
		position: relative;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--panel);
		box-shadow: 0 2px 10px var(--shadow);
		overflow: hidden;
		transform: translateZ(0);
		transform-style: preserve-3d;
		transform-origin: center center;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease,
			filter 180ms ease;
		will-change: transform;
	}

	.music-card:hover,
	.music-card:focus-within {
		border-color: color-mix(in srgb, var(--teal) 58%, var(--line));
		box-shadow: 0 12px 24px color-mix(in srgb, var(--ink) 18%, transparent);
		filter: saturate(1.06);
		transform: translateY(-5px);
	}

	.card-link {
		display: grid;
		grid-template-rows: 1fr auto;
		height: 100%;
		color: inherit;
		text-decoration: none;
	}

	.card-link::after {
		position: absolute;
		inset: 0;
		content: "";
		background:
			radial-gradient(circle at 18% 16%, rgba(255, 255, 255, 0.16), transparent 32%),
			linear-gradient(108deg, transparent 26%, rgba(255, 255, 255, 0.04) 40%, rgba(255, 255, 255, 0.16) 49%, rgba(255, 255, 255, 0.04) 58%, transparent 72%);
		opacity: 0;
		pointer-events: none;
		transform: translate3d(-28%, 0, 18px) skewX(-10deg);
		transition:
			opacity 180ms ease,
			transform 300ms ease;
	}

	.music-card:hover .card-link::after,
	.music-card:focus-within .card-link::after {
		opacity: 0.9;
		transform: translate3d(18%, 0, 18px) skewX(-8deg);
	}

	.cover {
		aspect-ratio: 1;
		display: grid;
		place-items: center;
		overflow: hidden;
		background: var(--wash);
	}

	.cover img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.cover span {
		color: var(--teal);
		font-size: 1.4rem;
		font-weight: 900;
	}

	.body {
		display: grid;
		gap: 6px;
		padding: 10px 11px 12px;
	}

	.meta {
		color: var(--muted);
		font-size: 0.72rem;
		font-weight: 800;
	}

	h3 {
		overflow: hidden;
		margin: 0;
		font-size: 0.93rem;
		line-height: 1.4;
		white-space: nowrap;
		text-overflow: ellipsis;
	}

	.fallback {
		width: fit-content;
		padding: 2px 7px;
		border: 1px solid var(--line);
		border-radius: 8px;
		color: var(--teal);
		background: var(--tag-bg);
		font-size: 0.72rem;
		font-weight: 800;
	}

	.hover-panel {
		position: absolute;
		inset: auto 0 0;
		display: grid;
		gap: 8px;
		padding: 54px 12px 12px;
		color: white;
		background:
			linear-gradient(180deg, transparent 0%, rgba(15, 22, 28, 0.76) 34%, rgba(15, 22, 28, 0.96) 100%);
		opacity: 0;
		pointer-events: none;
		transform: translateY(12px);
		transition:
			opacity 180ms ease,
			transform 180ms ease;
	}

	.music-card:hover .hover-panel,
	.music-card:focus-within .hover-panel {
		opacity: 1;
		transform: translateY(0);
	}

	.hover-label,
	.formats span,
	.tags span {
		width: fit-content;
		padding: 3px 7px;
		border-radius: 8px;
		font-size: 0.72rem;
	}

	.hover-label {
		border: 1px solid rgba(255, 255, 255, 0.24);
		background: rgba(255, 255, 255, 0.14);
		font-weight: 850;
	}

	p {
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 4;
		overflow: hidden;
		margin: 0;
		color: rgba(255, 255, 255, 0.86);
		font-size: 0.8rem;
		line-height: 1.62;
	}

	.formats,
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}

	.formats span {
		border: 1px solid hsl(var(--tag-hue) 76% 70% / 0.72);
		background: hsl(var(--tag-hue) 78% 58% / 0.18);
		color: hsl(var(--tag-hue) 86% 82%);
		font-weight: 800;
	}

	.tags span {
		border: 1px solid rgba(255, 255, 255, 0.16);
		background: rgba(255, 255, 255, 0.08);
		color: rgba(255, 255, 255, 0.78);
		font-weight: 760;
	}

	@media (hover: none), (pointer: coarse) {
		.music-card:hover,
		.music-card:focus-within {
			transform: translateY(-3px);
		}

		.hover-panel {
			display: none;
		}
	}
</style>
